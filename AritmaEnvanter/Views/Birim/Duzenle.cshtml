@model AritmaEnvanter.Models.Entities.Birim
@{
    ViewData["Title"] = "Birim Düzenle";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-pencil-square me-2" style="color:var(--accent);"></i>Birim Düzenle</h2>
        <p style="font-size:13px; color:var(--text-muted);">
            <i class="bi bi-house-door"></i> MASKİ &rsaquo; Birimler &rsaquo; Düzenle
        </p>
    </div>
    <div class="header-actions">
        <a asp-action="Index" class="btn-edit">
            <i class="bi bi-arrow-left"></i> Geri Dön
        </a>
    </div>
</div>

<div style="background:var(--accent-lt); border:1px solid rgba(0,168,232,0.15); border-radius:var(--radius); padding:14px 20px; margin-bottom:18px; display:flex; align-items:center; gap:10px;">
    <i class="bi bi-info-circle-fill" style="color:var(--accent); font-size:16px;"></i>
    <span style="font-size:13px; font-weight:600; color:var(--primary);">@Model.Ad birimini diğer hiyerarşiler içine taşıyabilirsiniz. Kendisini üst birim olarak seçemezsiniz.</span>
</div>

<div style="background:#fff; border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow); overflow:hidden;">
    <div style="background:linear-gradient(135deg, #003d7a, #005baa); padding:16px 24px; display:flex; align-items:center; gap:10px;">
        <i class="bi bi-diagram-3-fill" style="color:#fff; font-size:18px;"></i>
        <span style="color:#fff; font-size:15px; font-weight:700;">Birim Bilgileri</span>
    </div>

    <div style="padding:28px 24px;">
        <form asp-action="Duzenle" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OlusturmaTarihi" />

            <div class="row g-3" style="margin-bottom:28px;">
                <div class="col-md-6">
                    <label class="form-label" style="font-weight:700; font-size:13px; color:var(--text);">
                        Birim Adı <span style="color:var(--danger);">*</span>
                    </label>
                    <input asp-for="Ad" class="form-control" placeholder="Örn: Bilgi İşlem Dairesi Başkanlığı" />
                    <span asp-validation-for="Ad" style="color:var(--danger); font-size:12px;"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label" style="font-weight:700; font-size:13px; color:var(--text);">
                        Bağlı Olduğu Üst Birim (Opsiyonel)
                    </label>
                    <select asp-for="UstBirimId" class="form-select">
                        <option value="">-- Üst Birim Yok (Ana Birim) --</option>
                        @if (ViewBag.UstBirimler != null)
                        {
                            foreach (var b in ViewBag.UstBirimler)
                            {
                                <option value="@b.Id">@b.Ad</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="UstBirimId" style="color:var(--danger); font-size:12px;"></span>
                </div>
            </div>

            <div style="display:flex; gap:10px; justify-content:flex-end; border-top:1px solid var(--border); padding-top:20px;">
                <a asp-action="Index" class="btn-edit" style="padding:10px 24px;">
                    <i class="bi bi-x-lg"></i> İptal
                </a>
                <button type="submit" class="btn-cyan" style="padding:10px 28px;">
                    <i class="bi bi-check-lg"></i> Güncelle
                </button>
            </div>
        </form>
    </div>
</div>
