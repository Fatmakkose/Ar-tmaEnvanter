@model List<AritmaEnvanter.Models.Entities.MalzemeTalepForm>
@using AritmaEnvanter.Models.Entities
@{
    ViewData["Title"] = "Gelen Malzeme Talepleri";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-bell-fill me-2" style="color:var(--accent);"></i>Gelen Talepler</h2>
        <p>Personel tarafýndan oluŷturulan toplu malzeme taleplerini inceleyin ve onaylayýn.</p>
    </div>
</div>

@if (TempData["Basarili"] != null)
{
    <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> @TempData["Basarili"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="alert-err"><i class="bi bi-exclamation-triangle-fill"></i> @TempData["Hata"]</div>
}

<div class="data-card">
    <div class="data-card-head">
        <h6><i class="bi bi-list-stars"></i> Talep Listesi <span class="record-count">@Model.Count() Kayýt</span></h6>
    </div>
    <div class="table-responsive">
        <table class="table align-middle m-0">
            <thead>
                <tr>
                    <th>Form No</th>
                    <th>Talep Eden</th>
                    <th>Talep Edilen Ürünler</th>
                    <th>Talep Tarihi</th>
                    <th>Durum</th>
                    <th style="text-align:right;">Ýŷlem</th>
                </tr>
            </thead>


            <tbody>
                @foreach (var form in Model)
                {
                   
                    bool stokYetersiz = form.Satirlar.Any(s => s.Stok.Miktar < s.Miktar);

                    <tr>
                        <td>
                            <span class="badge bg-primary">MASKÝ-@form.FormSiraNo.ToString("D4")</span>
                        </td>
                        <td>
                            <div class="fw-bold">@form.TalepEdenPersonel?.AdSoyad</div>
                            <small class="text-muted">@form.TalepEdenPersonel?.Email</small>
                        </td>
                        <td>
                            <ul class="list-unstyled mb-0" style="font-size:13px;">
                                @foreach (var satir in form.Satirlar)
                                {
                                    var eksik = satir.Stok.Miktar < satir.Miktar;
                                    <li class="p-1 mb-1 @(eksik ? "bg-light-danger rounded" : "")">
                                        <i class="bi @(eksik ? "bi-exclamation-triangle-fill text-danger" : "bi-check-circle-fill text-success")"></i>
                                        <strong>@satir.Stok?.UrunAdi</strong>:
                                        <span class="fw-bold">@satir.Miktar</span> @satir.Stok?.Birim
                                        @if (eksik)
                                        {
                                            <span class="badge bg-danger ms-1" style="font-size:10px;">Eksik! Stokta: @satir.Stok.Miktar</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </td>
                        <td>@form.TalepTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>
                            @if (form.Durum == TalepDurumu.Beklemede)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Beklemede</span>
                            }
                            else if (form.Durum == TalepDurumu.Onaylandi)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i> Onaylandý</span>
                            }
                            else if (form.Durum == TalepDurumu.Reddedildi)
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-octagon"></i> Reddedildi</span>
                            }
                        </td>
                        <td style="text-align:right;">
                            @if (form.Durum == TalepDurumu.Beklemede)
                            {
                                <div class="d-flex justify-content-end gap-2">
                                    @if (!stokYetersiz)
                                    {
                                        <form asp-action="Onayla" asp-route-id="@form.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success">
                                                <i class="bi bi-check-lg"></i> Onayla
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Stokta eksik ürün olduŵu için onaylanamaz.">
                                            <i class="bi bi-lock-fill"></i> Kýsýtlý
                                        </button>
                                    }

                                    <form asp-action="Reddet" asp-route-id="@form.Id" method="post" onsubmit="return confirm('Bu talebi reddetmek istediŵinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-x-lg"></i> Red
                                        </button>
                                    </form>
                                </div>
                            }
                            else if (form.Durum == TalepDurumu.Onaylandi)
                            {
                                <a asp-action="TalepFormu" asp-route-id="@form.Id" target="_blank" class="btn btn-sm btn-dark">
                                    <i class="bi bi-printer-fill"></i> Yazdýr
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>

            <style>
                .bg-light-danger {
                    background-color: #fff5f5;
                    border-left: 3px solid #dc3545;
                    display: block;
                }
            </style>

