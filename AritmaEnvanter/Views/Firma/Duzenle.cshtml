@model AritmaEnvanter.Models.Entities.Firma

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h4 class="mb-0 text-primary"><i class="bi bi-pencil-square me-2"></i>Firma Düzenle</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Duzenle" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="FirmaAdi" class="form-label fw-medium text-dark"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-building"></i></span>
                            <input asp-for="FirmaAdi" class="form-control" placeholder="Firma Adı" />
                        </div>
                        <span asp-validation-for="FirmaAdi" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IlgiliKisiAdSoyad" class="form-label fw-medium text-dark"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-person-badge"></i></span>
                            <input asp-for="IlgiliKisiAdSoyad" class="form-control" placeholder="Ad Soyad" />
                        </div>
                        <span asp-validation-for="IlgiliKisiAdSoyad" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="IletisimNumarasi" class="form-label fw-medium text-dark"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                            <input asp-for="IletisimNumarasi" class="form-control" placeholder="05XX XXX XX XX" />
                        </div>
                        <span asp-validation-for="IletisimNumarasi" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light">
                            <i class="bi bi-arrow-left me-1"></i> İptal
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i> Güncelle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
