@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arıtma Envanter — Giriş</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700&family=Nunito+Sans:wght@700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            height: 100vh;
            display: flex;
            overflow: hidden;
            position: relative;
        }


        .left-panel {
            position: fixed;
            inset: 0;
            width: 100%;
            height: 100%;
        }

        .bg-image {
            position: absolute;
            inset: 0;
            background-image: url('/images/arkaplan.png');
            background-size: cover;
            background-position: center;
            filter: brightness(0.55) blur(2px); 
            
        }

        .blue-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient( 160deg, rgba(0, 42, 85, 0.6) 0%, rgba(0, 80, 160, 0.3) 50%, rgba(0, 168, 232, 0.2) 100% );
        }

       
        .bottom-fade {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 60%;
            background: linear-gradient(to top, rgba(0,30,70,0.92) 0%, transparent 100%);
        }

        .left-content {
            position: relative;
            z-index: 10;
            padding: 48px;
        }

        .left-logo {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 32px;
        }

        .left-logo-icon {
            width: 52px;
            height: 52px;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            border: 1.5px solid rgba(255,255,255,0.3);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
        }

        .left-logo-text {
            font-family: 'Nunito Sans', sans-serif;
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            letter-spacing: 1px;
        }

        .left-logo-sub {
            font-size: 11px;
            color: rgba(255,255,255,0.65);
            margin-top: 2px;
            letter-spacing: 0.3px;
        }

        .left-tagline {
            font-size: 32px;
            font-weight: 700;
            color: #fff;
            line-height: 1.3;
            margin-bottom: 16px;
        }

            .left-tagline span {
                color: #5dd5f9;
            }

        .left-desc {
            font-size: 15px;
            color: rgba(255,255,255,0.7);
            line-height: 1.7;
            max-width: 380px;
            margin-bottom: 36px;
        }

        .left-stats {
            display: flex;
            gap: 28px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-item-num {
            font-family: 'Nunito Sans', sans-serif;
            font-size: 26px;
            font-weight: 800;
            color: #5dd5f9;
        }

        .stat-item-lbl {
            font-size: 11px;
            color: rgba(255,255,255,0.6);
            margin-top: 2px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-divider {
            width: 1px;
            background: rgba(255,255,255,0.2);
            align-self: stretch;
        }

        
        .right-panel {
            width: 440px;
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px 44px;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.35);
            z-index: 100;
            max-height: 90vh;
            overflow-y: auto;
        }

            .right-panel::before {
                display:none;
            }

        .form-header {
            margin-bottom: 32px;
        }

            .form-header h2 {
                font-family: 'Nunito Sans', sans-serif;
                font-size: 24px;
                font-weight: 800;
                color: #003d7a;
                margin-bottom: 6px;
            }

            .form-header p {
                font-size: 14px;
                color: #64748b;
            }

        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 7px;
        }

        .input-wrap {
            position: relative;
        }

            .input-wrap i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 16px;
            }

        .form-input {
            width: 100%;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px 14px 12px 42px;
            font-family: 'Nunito', sans-serif;
            font-size: 14px;
            color: #1e293b;
            background: #f8faff;
            transition: all 0.2s;
            outline: none;
        }

            .form-input:focus {
                border-color: #00a8e8;
                box-shadow: 0 0 0 3px rgba(0,168,232,0.12);
                background: #fff;
            }

        .remember-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 24px;
        }

            .remember-row input[type="checkbox"] {
                width: 16px;
                height: 16px;
                accent-color: #003d7a;
                cursor: pointer;
            }

            .remember-row label {
                font-size: 13px;
                color: #475569;
                cursor: pointer;
                font-weight: 500;
            }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, #003d7a, #0066cc);
            color: #fff;
            border: none;
            padding: 13px;
            border-radius: 10px;
            font-family: 'Nunito', sans-serif;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            letter-spacing: 0.3px;
        }

            .btn-login:hover {
                background: linear-gradient(135deg, #002a55, #004f9e);
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(0,61,122,0.35);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
        }

            .divider hr {
                flex: 1;
                border: none;
                border-top: 1px solid #e2e8f0;
            }

            .divider span {
                font-size: 12px;
                color: #94a3b8;
                font-weight: 500;
            }

        .register-link {
            text-align: center;
            font-size: 13px;
            color: #64748b;
        }

            .register-link a {
                color: #0066cc;
                font-weight: 700;
                text-decoration: none;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }

        .error-box {
            background: #fff1f2;
            border: 1px solid #fecdd3;
            border-left: 4px solid #ef4444;
            border-radius: 8px;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-size: 13px;
            color: #b91c1c;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .right-footer {
            position: absolute;
            bottom: 24px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 11px;
            color: #cbd5e1;
        }

        @@media (max-width: 768px) {
            .left-panel {
                display: none;
            }

            .right-panel {
                width: 100%;
                padding: 40px 28px;
            }
        }
    </style>
</head>
<body>

 
    <div class="left-panel">
        <div class="bg-image"></div>
        <div class="blue-overlay"></div>
        <div class="bottom-fade"></div>

        <div class="left-content">
            <div class="left-logo">
                <img src="/images/maskilogo.png" alt="MaSKİ Logo"
                     style="height:64px; filter:brightness(0) invert(1);">

                </div> <!-- left-tagline -->
            </div> <!-- left-logo -->
        </div> <!-- left-content -->
    </div> <!-- left-panel -->
    <div class="right-panel">
            <div style="text-align:center;margin-bottom:20px;">
                <img src="/images/maskilogo.png" alt="MaSKİ Logo" style="height:60px;">
            </div>
        <div class="form-header">
            <h2>Hoş Geldiniz 👋</h2>
            <p>Devam etmek için hesabınıza giriş yapın.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-box">
                <i class="bi bi-exclamation-circle-fill"></i>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@error.ErrorMessage</span>
                }
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Login">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">E-posta Adresi</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input type="email" name="email" class="form-input"
                           placeholder="ornek@maski.gov.tr" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Şifre</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input type="password" name="password" class="form-input"
                           placeholder="••••••••" required>
                </div>
            </div>

            <div class="remember-row">
                <input type="checkbox" name="beniHatirla" id="beniHatirla">
                <label for="beniHatirla">Beni Hatırla</label>
            </div>

            <button type="submit" class="btn-login">
                <i class="bi bi-box-arrow-in-right"></i>
                Giriş Yap
            </button>
        </form>

        <div class="divider">
            <hr><span>veya</span><hr>
        </div>

        <div class="register-link">
            Hesabınız yok mu?
            <a asp-controller="Account" asp-action="Kayit">Yeni hesap oluşturun</a>
        </div>
           
        <div class="right-footer">
            © @DateTime.Now.Year MaSKİ — Tüm hakları saklıdır.
        </div>
    </div>

</body>
</html>
