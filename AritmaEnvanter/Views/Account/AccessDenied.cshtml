@{
    ViewData["Title"] = "Erişim Engellendi";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-6">
        <div class="card border-0 shadow-lg text-center p-5" style="border-radius: 20px;">
            <div class="mb-4">
                <i class="bi bi-shield-lock-fill text-danger" style="font-size: 80px;"></i>
            </div>
            <h2 class="fw-bold text-dark mb-3">Erişim Engellendi</h2>
            <p class="text-muted mb-4 px-4">
                Bu sayfayı görüntülemek için gerekli yetkiye sahip değilsiniz. Henüz bir ilçeye veya role atanmamış
                olabilirsiniz.
            </p>
            <div class="alert alert-warning border-0"
                style="background: #fff8e1; color: #a27b00; border-radius: 12px; font-size: 14px;">
                <i class="bi bi-info-circle-fill me-2"></i> Lütfen sistem yöneticinizle iletişime geçerek görev
                yerinizin tanımlanmasını isteyiniz.
            </div>
            <div class="mt-4 pt-2">
                <a href="/Home/Index" class="btn btn-maski px-4">
                    <i class="bi bi-house-door-fill"></i> Dashboard'a Dön
                </a>
            </div>
        </div>
