@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arıtma Envanter — Kayıt Ol</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;500;600;700&family=Nunito+Sans:wght@700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Nunito', sans-serif;
            min-height: 100vh;
            height: 100vh;
            display: flex;
            overflow: hidden;
            position: relative;
        }

        .bg-image {
            position: absolute;
            inset: 0;
            background-image: url('/images/arkaplan.png');
            background-size: cover;
            background-position: center;
            filter: brightness(0.55) blur(2px);
        }

        .blue-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient( 160deg, rgba(0, 42, 85, 0.6) 0%, rgba(0, 80, 160, 0.3) 50%, rgba(0, 168, 232, 0.2) 100% );
        }

        .form-panel {
            width: 460px;
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 36px 44px;
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.35);
            z-index: 100;
            max-height: 90vh;
            overflow-y: auto;
        }

        .logo-area {
            text-align: center;
            margin-bottom: 20px;
        }

            .logo-area img {
                height: 55px;
            }

        .form-header {
            margin-bottom: 24px;
            text-align: center;
        }

            .form-header h2 {
                font-family: 'Nunito Sans', sans-serif;
                font-size: 22px;
                font-weight: 800;
                color: #003d7a;
                margin-bottom: 4px;
            }

            .form-header p {
                font-size: 13px;
                color: #64748b;
            }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .input-wrap {
            position: relative;
        }

            .input-wrap i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 16px;
            }

        .form-input {
            width: 100%;
            border: 1.5px solid #e2e8f0;
            border-radius: 10px;
            padding: 11px 14px 11px 42px;
            font-family: 'Nunito', sans-serif;
            font-size: 14px;
            color: #1e293b;
            background: #f8faff;
            transition: all 0.2s;
            outline: none;
        }

            .form-input:focus {
                border-color: #00a8e8;
                box-shadow: 0 0 0 3px rgba(0,168,232,0.12);
                background: #fff;
            }

        .btn-register {
            width: 100%;
            background: linear-gradient(135deg, #003d7a, #0066cc);
            color: #fff;
            border: none;
            padding: 13px;
            border-radius: 10px;
            font-family: 'Nunito', sans-serif;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 8px;
        }

            .btn-register:hover {
                background: linear-gradient(135deg, #002a55, #004f9e);
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(0,61,122,0.35);
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
        }

            .divider hr {
                flex: 1;
                border: none;
                border-top: 1px solid #e2e8f0;
            }

            .divider span {
                font-size: 12px;
                color: #94a3b8;
                font-weight: 500;
            }

        .login-link {
            text-align: center;
            font-size: 13px;
            color: #64748b;
        }

            .login-link a {
                color: #0066cc;
                font-weight: 700;
                text-decoration: none;
            }

                .login-link a:hover {
                    text-decoration: underline;
                }

        .error-box {
            background: #fff1f2;
            border: 1px solid #fecdd3;
            border-left: 4px solid #ef4444;
            border-radius: 8px;
            padding: 12px 14px;
            margin-bottom: 16px;
            font-size: 13px;
            color: #b91c1c;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .stats-row {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            padding-top: 16px;
            border-top: 1px solid #f1f4fa;
        }

        .stat-item {
            text-align: center;
        }

        .stat-num {
            font-size: 15px;
            font-weight: 700;
            color: #003d7a;
        }

        .stat-lbl {
            font-size: 10px;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-div {
            width: 1px;
            background: #e2e8f0;
        }

        .bottom-text {
            text-align: center;
            font-size: 11px;
            color: #cbd5e1;
            margin-top: 16px;
        }
    </style>
</head>
<body>

    <div class="bg-image"></div>
    <div class="blue-overlay"></div>

    <div class="form-panel">
        <div class="logo-area">
            <img src="/images/maskilogo.png" alt="MaSKİ Logo">
        </div>

        <div class="form-header">
            <h2>Yeni Hesap Oluştur </h2>
            <p>Bilgilerinizi girerek kayıt olun.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-box">
                <i class="bi bi-exclamation-circle-fill"></i>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <span>@error.ErrorMessage</span>
                }
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Kayit">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Ad Soyad</label>
                <div class="input-wrap">
                    <i class="bi bi-person"></i>
                    <input type="text" name="adSoyad" class="form-input"
                           placeholder="Adınız Soyadınız" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">E-posta Adresi</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope"></i>
                    <input type="email" name="email" class="form-input"
                           placeholder="ornek@maski.gov.tr" required>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Şifre</label>
                <div class="input-wrap">
                    <i class="bi bi-lock"></i>
                    <input type="password" name="password" class="form-input"
                           placeholder="En az 6 karakter" required>
                </div>
            </div>

            <button type="submit" class="btn-register">
                <i class="bi bi-person-check"></i> Kayıt Ol
            </button>
        </form>

        <div class="divider"><hr><span>veya</span><hr></div>

        <div class="login-link">
            Zaten hesabınız var mı?
            <a asp-controller="Account" asp-action="Login">Giriş yapın</a>
        </div>

        <div class="stats-row">
            <div class="stat-item">
                <div class="stat-num">7/24</div>
                <div class="stat-lbl">Erişim</div>
            </div>
            <div class="stat-div"></div>
            <div class="stat-item">
                <div class="stat-num">%100</div>
                <div class="stat-lbl">Güvenli</div>
            </div>
            <div class="stat-div"></div>
            <div class="stat-item">
                <div class="stat-num">Anlık</div>
                <div class="stat-lbl">Güncelleme</div>
            </div>
        </div>

        <div class="bottom-text">© @DateTime.Now.Year MaSKİ — Tüm hakları saklıdır.</div>
    </div>

</body>
</html>