@model List<AritmaEnvanter.Models.Entities.DepoHareket>
@{
    ViewData["Title"] = "Stok Hareketleri Raporu";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
   
    <style>
        body { font-family: 'Arial', sans-serif; font-size: 12px; color: #333; margin: 0; padding: 20px; }
        .rapor-header { display: flex; align-items: center; justify-content: space-between; border-bottom: 2px solid #000; padding-bottom: 15px; margin-bottom: 20px; }
        .logo-area { display: flex; align-items: center; }
        .logo-area img { height: 75px; margin-right: 20px; }
        .logo-area div { font-size: 22px; font-weight: bold; color: #000; }
        .rapor-title { text-align: right; }
        .rapor-title h2 { margin: 0; font-size: 20px; color: #000; }
        .rapor-title p { margin: 5px 0 0 0; font-size: 12px; color: #555; }
        
        .filter-info { margin-bottom: 20px; padding: 12px; background: #f9f9f9; border: 1px solid #ddd; display: flex; flex-wrap: wrap; gap: 15px; }
        .filter-item { font-size: 13px; }
        .filter-item strong { color: #000; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
        th, td { border: 1px solid #000; padding: 8px 10px; text-align: left; font-size: 12px; }
        th { background-color: #f2f2f2; font-weight: bold; text-transform: uppercase; font-size: 11px; }
        tr:nth-child(even) { background-color: #f9f9f9; }
        
        @@media print {
            body { padding: 0; }
            .no-print { display: none !important; }
            .filter-info { background: transparent; border: none; padding: 0; border-bottom: 1px dashed #ccc; margin-bottom: 20px; padding-bottom: 10px; }
            tr:nth-child(even) { background-color: transparent; }
        }
        .text-center { text-align: center; }
        .text-right { text-align: right; }
    </style>
</head>
<body>
    <div class="no-print" style="margin-bottom: 20px; text-align: right;">
        <button onclick="window.print()" style="padding: 10px 20px; background: #0056b3; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: bold;">
            Yazdır / PDF Olarak Kaydet
        </button>
    </div>

    <div class="rapor-header">
        <div class="logo-area">
            <img src="/images/maskilogo.png" alt="MASKİ Logo" onerror="this.onerror=null; this.src=''; this.alt='MASKİ';" />
            <div>
                
                <div style="font-size: 16px; font-weight: normal; margin-top: 4px;">Arıtma Tesisleri Dairesi Başkanlığı</div>
            </div>
        </div>
        <div class="rapor-title">
            <h2>STOK HAREKETLERİ RAPORU</h2>
            <p>Rapor Tarihi: @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</p>
        </div>
    </div>

    <div class="filter-info">
        @if (!string.IsNullOrEmpty(ViewBag.Arama))
        {
            <div class="filter-item"><strong>Arama Kriteri:</strong> @ViewBag.Arama</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.IslemTipi))
        {
            <div class="filter-item"><strong>İşlem Türü:</strong> @(ViewBag.IslemTipi == "Giris" ? "Giriş" : ViewBag.IslemTipi == "Cikis" ? "Çıkış" : "İade")</div>
        }
        @if (!string.IsNullOrEmpty(ViewBag.BaslangicTarihi) || !string.IsNullOrEmpty(ViewBag.BitisTarihi))
        {
            <div class="filter-item"><strong>Tarih Aralığı:</strong> @(ViewBag.BaslangicTarihi ?? "-") / @(ViewBag.BitisTarihi ?? "-")</div>
        }
        <div class="filter-item"><strong>Toplam Kayıt:</strong> @Model.Count</div>
    </div>

    <table>
        <thead>
            <tr>
                <th style="width: 110px;">Tarih</th>
                <th>Depo & Mevki Bilgisi</th>
                <th>Ürün Adı</th>
                <th style="width: 60px; text-align: center;">Adet</th>
                <th>Teslim Alan</th>
                <th>İşlem Yapan / Kullanıcı</th>
                <th style="width: 80px;">İşlem Türü</th>
                <th>Firma</th>
                <th>Belge No</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="9" class="text-center" style="padding: 20px;">Belirtilen kriterlere uygun stok hareketi bulunamadı.</td>
                </tr>
            }
            else
            {
                foreach (var hareket in Model)
                {
                    string islemTuru = "Belirsiz";
                    string islemIsareti = "";
                    if (hareket.HedefDepoId == null) { islemTuru = "Çıkış"; islemIsareti = "-"; }
                    else if (hareket.KaynakDepoId == hareket.HedefDepoId) { islemTuru = "Giriş"; islemIsareti = "+"; }
                    else if (hareket.KaynakDepoId == null && hareket.HedefDepoId != null) { islemTuru = "İade"; islemIsareti = "+"; }
                    else { islemTuru = "Transfer"; }

                    string depoBilgisi = "";
                    if (islemTuru == "Çıkış")
                    {
                        depoBilgisi = "Nereden: " + (hareket.KaynakDepo?.Ad ?? "");
                    }
                    else
                    {
                        depoBilgisi = "Nereye: " + (hareket.HedefDepo?.Ad ?? "");
                    }
                    if (!string.IsNullOrEmpty(hareket.RafNo))
                    {
                        depoBilgisi += " / Raf: " + hareket.RafNo;
                    }

                    <tr>
                        <td>@hareket.Tarih.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@depoBilgisi</td>
                        <td><strong>@(hareket.Malzeme?.Ad ?? "")</strong></td>
                        <td class="text-center"><strong>@islemIsareti@hareket.Miktar</strong></td>
                        <td>@(hareket.Personel?.AdSoyad ?? "—")</td>
                        <td>@(hareket.IslemYapanKisi ?? "Sistem")</td>
                        <td>@islemTuru</td>
                        <td>@(hareket.Firma?.FirmaAdi ?? "—")</td>
                        <td>@(hareket.CikisFormNo ?? "—")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div style="margin-top: 40px; text-align: right; font-size: 11px; color: #777;">
         Onay / İmza ______________
    </div>

    
    <script>
        window.onload = function() {
            setTimeout(function() {
                window.print();
            }, 500);
        }
    </script>
</body>
</html>
