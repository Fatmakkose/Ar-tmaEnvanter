<div class="modal fade" id="importExcelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light">
                <h5 class="modal-title" style="color:#003d7a;font-weight:700;">
                    <i class="bi bi-file-earmark-arrow-up me-2"></i>Excel'den Kayıt Aktar
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <form asp-action="ExcelImport" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <div class="alert alert-info border-0 shadow-sm mb-4" style="font-size:13px;">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Lütfen önce <strong>"Şablon İndir"</strong> butonu ile güncel şablonu indirin ve verilerinizi bu şablona göre hazırlayın.
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold" style="font-size:14px;">Excel Dosyası Seçin</label>
                        <input type="file" name="excelFile" class="form-control" accept=".xlsx, .xls" required>
                        <div class="form-text mt-2">Sadece .xlsx ve .xls formatları desteklenir.</div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn-outline-clear" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn-cyan">
                        <i class="bi bi-cloud-upload me-1"></i> Aktarımı Başlat
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="printBarcodeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="color:#003d7a;font-weight:700;">
                    <i class="bi bi-printer me-2"></i>Barkod Çıktısı
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body text-center">
                <div id="printArea" style="padding:20px; background:#fff; border:1px solid #ccc; border-radius:12px; margin-bottom:15px; display:inline-block; min-width: 250px;">
                    <img src="/images/maskilogo.png" alt="MaSKİ" style="height:30px; filter:brightness(0); margin-bottom:8px;">
                    <div id="barcodeTitle" style="font-size:13px; font-weight:700; margin-bottom:10px; color:#333; text-transform:uppercase;"></div>
                    <div id="barcodeValue" style="font-size:14px; font-weight:700; font-family:monospace; letter-spacing:1px; margin-bottom:5px; color:#000;"></div>
                    <svg id="barcodeSvg"></svg>
                </div>
                <div class="d-grid">
                    <button type="button" class="btn-cyan" onclick="printBarcode()">
                        <i class="bi bi-printer-fill me-1"></i> Çıktı Al
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script>
        let printModal = null;

        function showBarcode(barkodNo, title) {
            if (!barkodNo) return;

            if (!printModal) {
                printModal = new bootstrap.Modal(document.getElementById('printBarcodeModal'));
            }

            document.getElementById('barcodeTitle').innerText = title;
            document.getElementById('barcodeValue').innerText = barkodNo;
            JsBarcode("#barcodeSvg", barkodNo, {
                format: "CODE128",
                lineColor: "#000",
                width: 2,
                height: 50,
                displayValue: false,
                fontSize: 14,
                fontOptions: "bold"
            });

            printModal.show();
        }

        function printBarcode() {
            const printContent = document.getElementById('printArea').innerHTML;
            const originalContent = document.body.innerHTML;

            document.body.innerHTML = `
                <div style="width:100%; height:100vh; display:flex; justify-content:center; align-items:center;">
                    <div style="text-align:center;">${printContent}</div>
                </div>`;
            
            window.print();
            
            document.body.innerHTML = originalContent;
            window.location.reload();
        }
    </script>
}