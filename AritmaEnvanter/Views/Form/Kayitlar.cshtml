                                    }
                                </td>
                                <td style="font-size:12px;color:#94a3b8;">@urun.OlusturmaTarihi.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td>
                                    <a href="/Urun/Detay/@urun.Id" class="btn-link text-primary text-decoration-none small"><i class="bi bi-eye"></i> Detay</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (ViewBag.DepoStoklar != null && ((List<AritmaEnvanter.Models.Entities.DepoStok>)ViewBag.DepoStoklar).Any())
