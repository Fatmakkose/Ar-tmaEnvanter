                                <td style="font-weight:600; color:#0369a1;">@stok.UrunAdi</td>
                                <td class="fw-bold fs-5">@stok.Miktar</td>
                                <td>@stok.Birim</td>
                                <td style="font-size:12px; color:#64748b;">@stok.GuncellemeTarihi.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td>
                                    <a href="/Depo/Detay/@stok.DepoId" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-right-circle"></i> Depoya Git</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
