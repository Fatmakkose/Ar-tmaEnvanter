@model AritmaEnvanter.Models.Entities.FormSablon
@{
    ViewData["Title"] = Model.Baslik + " — Kayıtlar";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-table me-2" style="color:#00a8e8;"></i>@Model.Baslik — Kayıtlar</h2>
        @{
            int totalCount = Model.Kayitlar.Count;
            if (ViewBag.StandartUrunler != null) totalCount += ((List<AritmaEnvanter.Models.Entities.Malzeme>)ViewBag.StandartUrunler).Count;
            if (ViewBag.DepoStoklar != null) totalCount += ((List<AritmaEnvanter.Models.Entities.DepoStok>)ViewBag.DepoStoklar).Count;
        }
        <p>@totalCount adet toplam kayıt</p>
    </div>
    <div class="header-actions">
        <div class="dropdown d-inline-block me-2">
            <button class="btn-outline-filter dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-gear-wide-connected"></i> Toplu İşlemler
            </button>
            <ul class="dropdown-menu shadow-sm border-0" style="font-size:14px;">
                <li>
                    <a class="dropdown-item py-2" asp-action="ExcelSablon" asp-route-id="@Model.Id">
                        <i class="bi bi-file-earmark-spreadsheet me-2 text-success"></i> Şablon İndir
                    </a>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <button type="button" class="dropdown-item py-2" data-bs-toggle="modal" data-bs-target="#importExcelModal">
                            <i class="bi bi-file-earmark-arrow-up me-2 text-primary"></i> Excel'den Aktar
                        </button>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item py-2 text-danger" asp-action="Temizle" onclick="return confirm('Boş ve kategorisiz ürün tanımlarını temizlemek istediğinize emin misiniz?')">
                            <i class="bi bi-trash-fill me-2"></i> Artık Kayıtları Temizle
                        </a>
                    </li>
                }
            </ul>
        </div>
        <a asp-action="Doldur" asp-route-id="@Model.Id" class="btn-cyan">
            <i class="bi bi-plus-lg"></i> Yeni Kayıt
        </a>
        <a asp-action="Index" class="btn-outline-clear">
            <i class="bi bi-arrow-left"></i> Şablonlara Dön
        </a>
    </div>
</div>
<div class="filter-bar">
    <form method="get" class="d-flex gap-2 flex-wrap align-items-center w-100">
        <input type="hidden" name="id" value="@Model.Id">
        <div style="position:relative;flex:1;min-width:200px;">
            <i class="bi bi-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:13px;"></i>
            <input type="text" name="arama" value="@ViewBag.Arama"
                   class="form-control" style="padding-left:34px;"
                   placeholder="Kayıt içinde ara...">
        </div>
        <input type="date" name="baslangic" value="@ViewBag.Baslangic" class="form-control" style="width:160px;">
        <input type="date" name="bitis" value="@ViewBag.Bitis" class="form-control" style="width:160px;">
        <button type="submit" class="btn-outline-filter"><i class="bi bi-funnel"></i> Filtrele</button>
        <a asp-action="Kayitlar" asp-route-id="@Model.Id" class="btn-outline-clear"><i class="bi bi-x"></i> Temizle</a>
    </form>
</div>

@if (Model.Kayitlar.Any())
{
    <div class="data-card">
        <div class="data-card-head">
            <h6><i class="bi bi-list-ul"></i> Form Kayıtları <span class="record-count">@Model.Kayitlar.Count kayıt</span></h6>
        </div>
        <div style="overflow-x:auto;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Kayıt No</th>
                        @foreach (var alan in Model.Alanlar.OrderBy(a => a.Sira))
                        {
                            <th>@alan.AlanAdi</th>
                        }
                        <th>Kaydeden</th>
                        <th>Tarih</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kayit in Model.Kayitlar.OrderBy(k => k.OlusturmaTarihi))
                    {
                        <tr>
                            <td>
                                <span style="background:#eff6ff;color:#003d7a;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:700;">
                                    @kayit.KayitNo
                                </span>
                            </td>
                            @foreach (var alan in Model.Alanlar.OrderBy(a => a.Sira))
                            {
                                var kayitDeger = kayit.Degerler.FirstOrDefault(d => d.FormAlanId == alan.Id);
                                <td style="font-size:13px;">
                                    @if (kayitDeger?.GorselUrl != null)
                                    {
                                        <img src="@kayitDeger.GorselUrl"
                                             style="width:60px;height:60px;object-fit:cover;border-radius:6px;cursor:pointer;"
                                             onclick="this.requestFullscreen()" title="Büyütmek için tıkla">
                                    }
                                    else if (alan.AlanAdi.Equals("Demirbaş No", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrEmpty(kayit.Barkod))
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;">
                                            <span style="font-family:monospace;font-weight:700;color:#003d7a;letter-spacing:0.5px;">@kayit.Barkod</span>
                                            <button type="button" class="btn-cyan" style="padding:2px 6px;font-size:11px;" onclick="showBarcode('@kayit.Barkod', '@Model.Baslik Kayıt @kayit.KayitNo')" title="Yazdır">
                                                <i class="bi bi-printer-fill"></i>
                                            </button>
                                        </div>
                                    }
                                    else if (alan.AlanTipi == "Durum")
                                    {
                                        var val = kayitDeger?.Deger ?? "—";
                                        if (val == "Aktif")
                                        {
                                            <span style="background:#dcfce7;color:#166534;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;"><i class="bi bi-check-circle-fill"></i> Aktif</span>
                                        }
                                        else if (val == "Pasif")
                                        {
                                            <span style="background:#fee2e2;color:#991b1b;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;"><i class="bi bi-x-circle-fill"></i> Pasif</span>
                                        }
                                        else if (val == "Hurda")
                                        {
                                            <span style="background:#fee2e2;color:#991b1b;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:600;"><i class="bi bi-trash-fill"></i> Pasif (Hurda)</span>
                                        }
                                        else 
                                        {
                                            @val
                                        }
                                    }
                                    else
                                    {
                                        @(kayitDeger?.Deger ?? "—")
                                    }
                                </td>
                            }
                            <td style="font-size:12px;color:#64748b;">@(kayit.KaydedenKullanici ?? "—")</td>
                            <td style="font-size:12px;color:#94a3b8;">@kayit.OlusturmaTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <form asp-action="SilKayit" asp-route-id="@kayit.Id" asp-route-formId="@Model.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Bu kaydı silmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-del" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                
            </table>
        </div>
    </div>

    @if (ViewBag.StandartUrunler != null && ((List<AritmaEnvanter.Models.Entities.Malzeme>)ViewBag.StandartUrunler).Any())
    {
        <div class="data-card mt-4" style="border-top: 3px solid #003d7a;">
            <div class="data-card-head" style="background:#f8f9fc;">
                <h6><i class="bi bi-box-seam"></i> Depo Girişleri (Standart Ürünler) <span class="record-count">@(((List<AritmaEnvanter.Models.Entities.Malzeme>)ViewBag.StandartUrunler).Count) kayıt</span></h6>
