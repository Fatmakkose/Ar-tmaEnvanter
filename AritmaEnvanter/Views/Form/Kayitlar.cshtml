                                        <button type="button" class="btn-cyan" style="padding:2px 6px;font-size:11px;" onclick="showBarcode('@urun.SeriNo', '@urun.UrunTuru')" title="Yazdır">
                                            <i class="bi bi-printer-fill"></i>
                                        </button>
                                    </div>
                                </td>
                                <td style="font-weight:600;">@(urun.UrunTuru ?? urun.Ad)</td>
                                <td>@urun.Miktar</td>
                                <td>
                                    @if (urun.Durum == "Aktif")
                                    {
                                        <span class="badge bg-success-subtle text-success px-2 py-1 rounded-pill" style="font-size: 11px; font-weight: 600;">Aktif</span>
                                    }
                                    else if (urun.Durum == "Bakımda")
