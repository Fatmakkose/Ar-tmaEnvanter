@model List<AritmaEnvanter.Models.Entities.FormKayit>
@{
    ViewData["Title"] = "Tüm Varlıklar";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-grid-3x3-gap-fill me-2" style="color:#00a8e8;"></i>Tüm Varlıklar</h2>
        <p>Sistemde kayıtlı tüm dinamik varlık kayıtlarının listesi</p>
    </div>
    <div class="header-actions">
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Temizle" class="btn-outline-clear text-danger me-2" onclick="return confirm('Boş ve kategorisiz ürün tanımlarını temizlemek istediğinize emin misiniz?')">
                <i class="bi bi-trash-fill"></i> Artık Kayıtları Temizle
            </a>
        }
        <a asp-action="Index" class="btn-outline-clear">
            <i class="bi bi-arrow-left"></i> Şablonlara Dön
        </a>
    </div>
</div>

<div class="filter-bar">
    <form method="get" class="d-flex gap-2 flex-wrap align-items-center w-100">
        <div style="position:relative;flex:1;min-width:200px;">
            <i class="bi bi-search" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:13px;"></i>
            <input type="text" name="arama" value="@ViewBag.Arama"
                   class="form-control" style="padding-left:34px;"
                   placeholder="Kayıt, Barkod veya Şablon adı ile ara...">
        </div>
        <button type="submit" class="btn-outline-filter"><i class="bi bi-funnel"></i> Filtrele</button>
        <a asp-action="TumVarliklar" class="btn-outline-clear"><i class="bi bi-x"></i> Temizle</a>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-inbox" style="font-size:44px;opacity:0.3;display:block;margin-bottom:12px;"></i>
        <p>Gösterilecek herhangi bir kayıt bulunamadı.</p>
    </div>
}
else
{
    <div class="data-card">
        <div class="data-card-head">
            <h6><i class="bi bi-list-stars"></i> Toplu Varlık Listesi <span class="record-count">@Model.Count kayıt</span></h6>
        </div>
        <div class="table-responsive" style="border-radius:0 0 12px 12px;">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="min-width:160px;">Barkod / Demirbaş</th>
                        <th class="text-center" style="width:60px;">Yazdır</th>
                        <th style="width:100px;">Kayıt No</th>
                        <th>Şablon / Varlık Türü</th>
                        <th>Kategori</th>
                        <th>Birim / Raf</th>
                        <th>Kaydeden</th>
                        <th style="min-width:140px;">Tarih</th>
                        <th class="text-end" style="width:80px;">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var kayit in Model)
                    {
                        <tr>
                            <td>
                                <span style="font-family: 'JetBrains Mono', monospace; font-weight:700; color:#0f172a; letter-spacing:0.5px; font-size:13px;">
                                    @kayit.Barkod
                                </span>
                            </td>
                            <td class="text-center">
                                <button type="button" class="btn-cyan shadow-sm" style="width:32px; height:32px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:8px;" 
                                        onclick="showBarcode('@kayit.Barkod', '@kayit.FormSablon.Baslik Kayıt @kayit.KayitNo')" title="Barkod Yazdır">
                                    <i class="bi bi-printer-fill" style="font-size:14px;"></i>
                                </button>
                            </td>
                            <td>
                                <span style="background:#f1f5f9; color:#475569; padding:4px 10px; border-radius:6px; font-size:12px; font-weight:700; border:1px solid #e2e8f0; display:inline-block; min-width:50px; text-align:center;">
                                    @kayit.KayitNo
                                </span>
                            </td>
                            <td>
                                <div style="font-weight:600; color:#1e293b; font-size:14px;">@kayit.FormSablon.Baslik</div>
                            </td>
                            <td>
                                @if (kayit.FormSablon.Kategori != null)
                                {
                                    <span class="badge bg-light text-dark border px-2 py-1" style="font-size:11px; font-weight:500;">
                                        <i class="bi bi-tag-fill me-1 text-secondary"></i>@kayit.FormSablon.Kategori.Ad
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Kategorisiz</span>
                                }
                            </td>
                            <td>
                                @if (kayit.Depo != null)
                                {
                                    <div class="d-flex align-items-center gap-2" style="font-size:13px; color:#1e293b;">
                                        <div style="width:24px; height:24px; background:#e0f2fe; color:#0369a1; border-radius:6px; display:flex; align-items:center; justify-content:center;">
                                            <i class="bi bi-house-door-fill" style="font-size:12px;"></i>
                                        </div>
                                        <span style="font-weight:500;">@kayit.Depo.Ad</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center gap-2" style="font-size:13px; color:#475569;">
                                        <div style="width:24px; height:24px; background:#f1f5f9; color:#64748b; border-radius:6px; display:flex; align-items:center; justify-content:center;">
                                            <i class="bi bi-building" style="font-size:12px;"></i>
                                        </div>
                                        <span>@(kayit.Birim?.Ad ?? "Birim Tanımsız")</span>
                                    </div>
                                }
                            </td>
                            <td>
                                <div style="font-size:12px; color:#64748b; max-width:150px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@kayit.KaydedenKullanici">
                                    <i class="bi bi-person me-1"></i>@(kayit.KaydedenKullanici ?? "—")
                                </div>
                            </td>
                            <td>
                                <div style="font-size:12px; color:#64748b; white-space:nowrap;">
                                    <i class="bi bi-calendar3 me-1 opacity-50"></i>@kayit.OlusturmaTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                </div>
                            </td>
                            <td class="text-end">
                                <a asp-action="Kayitlar" asp-route-id="@kayit.FormSablonId" class="btn-edit shadow-sm" style="width:32px; height:32px; padding:0; display:flex; align-items:center; justify-content:center; border-radius:8px; margin-left:auto;" title="Şablon Kayıtlarını Gör">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}


<div class="modal fade" id="printBarcodeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" style="color:#003d7a;font-weight:700;">
                    <i class="bi bi-printer me-2"></i>Barkod Çıktısı
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body text-center">
                <div id="printArea" style="padding:20px; background:#fff; border:1px solid #ccc; border-radius:12px; margin-bottom:15px; display:inline-block; min-width: 250px;">
                    <img src="/images/maskilogo.png" alt="MaSKİ" style="height:30px; filter:brightness(0); margin-bottom:8px;">
                    <div id="barcodeTitle" style="font-size:13px; font-weight:700; margin-bottom:10px; color:#333; text-transform:uppercase;"></div>
                    <div id="barcodeValue" style="font-size:14px; font-weight:700; font-family:monospace; letter-spacing:1px; margin-bottom:5px; color:#000;"></div>
                    <svg id="barcodeSvg"></svg>
                </div>
                <div class="d-grid">
                    <button type="button" class="btn-cyan" onclick="printBarcode()">
                        <i class="bi bi-printer-fill me-1"></i> Çıktı Al
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script>
        let printModal = null;

        function showBarcode(barkodNo, title) {
            if (!barkodNo) return;

            if (!printModal) {
                printModal = new bootstrap.Modal(document.getElementById('printBarcodeModal'));
            }

            document.getElementById('barcodeTitle').innerText = title;
            document.getElementById('barcodeValue').innerText = barkodNo;
            JsBarcode("#barcodeSvg", barkodNo, {
                format: "CODE128",
                lineColor: "#000",
                width: 2,
                height: 50,
                displayValue: false,
                fontSize: 14,
                fontOptions: "bold"
            });

            printModal.show();
        }

        function printBarcode() {
            const printContent = document.getElementById('printArea').innerHTML;
            const originalContent = document.body.innerHTML;

            document.body.innerHTML = `
                <div style="width:100%; height:100vh; display:flex; justify-content:center; align-items:center;">
                    <div style="text-align:center;">${printContent}</div>
                </div>`;
            
            window.print();
            
            document.body.innerHTML = originalContent;
            window.location.reload();
        }
    </script>
}
