<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AritmaEnvanter.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AritmaEnvanter.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="Arıtma Envanter">

    <!-- Login Page -->
    <ShellContent
        Title="Giriş"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="Login"
        Shell.FlyoutBehavior="Disabled"
        Shell.TabBarIsVisible="False"
        Shell.NavBarIsVisible="False" />

    <!-- Main Navigation with Tabs (Hidden) -->
    <TabBar Shell.TabBarIsVisible="False">
        <Tab Title="Ürünler">
            <ShellContent
                Title="Ürün Listesi"
                ContentTemplate="{DataTemplate views:InventoryPage}"
                Route="Stoklar" />
        </Tab>

        <Tab Title="Hareketler">
            <ShellContent
                Title="İşlem Geçmişi"
                ContentTemplate="{DataTemplate views:MovementsPage}"
                Route="Hareketler" />
        </Tab>

        <Tab Title="Talepler">
            <ShellContent
                Title="Talepler"
                ContentTemplate="{DataTemplate views:RequestPage}"
                Route="Talepler" />
        </Tab>
    </TabBar>

</Shell>
