<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AritmaEnvanter.Mobile.Views.RequestPage"
             Title="Malzeme Talebi">

    <Grid RowDefinitions="*, Auto" Padding="20">
        
        <VerticalStackLayout Grid.Row="0" Spacing="15">
            <Label Text="Yeni Talep Oluştur" FontSize="20" FontAttributes="Bold" />
            
            <Label Text="Genel Açıklama" />
            <Frame Padding="10,0" HasShadow="False" BackgroundColor="#F5F5F5">
                <Editor Placeholder="Talebinizle ilgili notlar..." HeightRequest="100" />
            </Frame>

            <Label Text="Seçilen Ürünler (0)" FontAttributes="Bold" Margin="0,10,0,0" />
            
            <BoxView HeightRequest="1" Color="#E1E1E1" />
            
            <Label Text="Talep listesine ürün eklemek için stok listesinden seçim yapabilirsiniz." 
                   TextColor="Gray" 
                   FontSize="12" 
                   HorizontalOptions="Center" 
                   Margin="0,20" />

            <Button Text="+ ÜRÜN EKLE"
                    BorderColor="#512BD4"
                    BorderWidth="1"
                    BackgroundColor="Transparent"
                    TextColor="#512BD4"
                    FontAttributes="Bold"
                    CornerRadius="10" />
        </VerticalStackLayout>

        <Button Grid.Row="1"
                Text="TALEBİ GÖNDER"
                BackgroundColor="#512BD4"
                TextColor="White"
                FontAttributes="Bold"
                HeightRequest="50"
                CornerRadius="10"
                Margin="0,20,0,0" />

    </Grid>
</ContentPage>
