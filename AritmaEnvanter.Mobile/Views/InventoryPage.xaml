<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AritmaEnvanter.Mobile.ViewModels"
             xmlns:models="clr-namespace:AritmaEnvanter.Mobile.Models"
             xmlns:converters="clr-namespace:AritmaEnvanter.Mobile.Converters"
             xmlns:controls="clr-namespace:AritmaEnvanter.Mobile.Controls"
             x:Class="AritmaEnvanter.Mobile.Views.InventoryPage"
             BackgroundColor="#EEF3FF"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
        
        <Style TargetType="Label" x:Key="HeaderLabel">
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>
    </ContentPage.Resources>

    <Grid>
        <!-- Main Layout -->
        <Grid RowDefinitions="Auto, *">
            <!-- Premium Header -->
            <Border Grid.Row="0" StrokeThickness="0" HeightRequest="170" VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,40,40" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3E78EA" Offset="0.0" />
                        <GradientStop Color="#5894F2" Offset="0.5" />
                        <GradientStop Color="#84B9FF" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid RowDefinitions="Auto, *" Padding="20,18,20,18" RowSpacing="14">
                    <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Center" Spacing="15">
                        <Border BackgroundColor="White" Padding="8" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Image Source="logo.png" WidthRequest="35" HeightRequest="35" />
                        </Border>
                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="ARITMA ENVANTER" FontSize="18" FontAttributes="Bold" TextColor="White" CharacterSpacing="1" />
                            <Label Text="Stok Yönetim Sistemi" FontSize="11" TextColor="White" Opacity="0.9" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Stat Cards Grid -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <!-- Kritik Card -->
                        <Border Grid.Column="0" BackgroundColor="#FFEDEE" Stroke="#F4B7BC" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="8" HeightRequest="70">
                            <Border.Shadow>
                                <Shadow Brush="#B9CCEE" Offset="0,2" Radius="6" Opacity="0.3" />
                            </Border.Shadow>
                            <Grid>
                                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding CriticalCount}" FontSize="22" FontAttributes="Bold" TextColor="#D94444" HorizontalOptions="Center" />
                                    <Label Text="KRİTİK" FontSize="9" FontAttributes="Bold" TextColor="#555" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                                <Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="#D94444" WidthRequest="18" HeightRequest="18" StrokeShape="RoundRectangle 5" Margin="0,-3,-3,0">
                                    <Label Text="⚠" TextColor="White" FontSize="10" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Giriş Card -->
                        <Border Grid.Column="1" BackgroundColor="#ECF9F1" Stroke="#A8DFC1" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="8" HeightRequest="70">
                            <Border.Shadow>
                                <Shadow Brush="#B9CCEE" Offset="0,2" Radius="6" Opacity="0.3" />
                            </Border.Shadow>
                            <Grid>
                                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding TodayEntryCount}" FontSize="22" FontAttributes="Bold" TextColor="#0D6166" HorizontalOptions="Center" />
                                    <Label Text="GİRİŞ" FontSize="9" FontAttributes="Bold" TextColor="#555" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                                <Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="#0D6166" WidthRequest="18" HeightRequest="18" StrokeShape="RoundRectangle 5" Margin="0,-3,-3,0">
                                    <Label Text="→" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Çıkış Card -->
                        <Border Grid.Column="2" BackgroundColor="#FFF4E8" Stroke="#F6CFAB" StrokeThickness="1" StrokeShape="RoundRectangle 14" Padding="8" HeightRequest="70">
                            <Border.Shadow>
                                <Shadow Brush="#B9CCEE" Offset="0,2" Radius="6" Opacity="0.3" />
                            </Border.Shadow>
                            <Grid>
                                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding TodayExitCount}" FontSize="22" FontAttributes="Bold" TextColor="#D68B09" HorizontalOptions="Center" />
                                    <Label Text="ÇIKIŞ" FontSize="9" FontAttributes="Bold" TextColor="#555" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                                <Border HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="#D68B09" WidthRequest="18" HeightRequest="18" StrokeShape="RoundRectangle 5" Margin="0,-3,-3,0">
                                    <Label Text="←" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*">
                <VerticalStackLayout Grid.Row="0" Padding="20,12,20,10" Spacing="14">
                    <!-- Search Bar -->
                    <Border StrokeThickness="1" Stroke="#D3E1FB" BackgroundColor="White" HeightRequest="54" StrokeShape="RoundRectangle 18">
                        <Border.Shadow>
                            <Shadow Brush="#C6D9FB" Offset="0,2" Radius="6" Opacity="0.35" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="20,0">
                            <Label Grid.Column="0" Text="🔍" FontSize="16" VerticalOptions="Center" TextColor="#6E91CE" />
                            <Entry Grid.Column="1"
                                   Placeholder="Ürün veya raf ara..."
                                   Text="{Binding SearchText}"
                                   BackgroundColor="Transparent"
                                   FontSize="14"
                                   VerticalOptions="Center"
                                   Margin="10,0"
                                   TextColor="#1F3768"
                                   PlaceholderColor="#8EA6D2" />
                            <Label Grid.Column="2" Text="⌕" FontSize="18" VerticalOptions="Center" TextColor="#6E91CE" />
                        </Grid>
                    </Border>

                    <!-- Quick Actions -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Hızlı İşlemler" FontSize="15" FontAttributes="Bold" TextColor="#333" Margin="5,0" />
                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="12">
                            <Border Grid.Column="0" BackgroundColor="#1D8AA4" StrokeShape="RoundRectangle 12" HeightRequest="48" StrokeThickness="0">
                                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                    <Label Text="GİRİŞ" TextColor="White" FontAttributes="Bold" FontSize="12" />
                                    <Label Text="→" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenEntryCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="1" BackgroundColor="#D97466" StrokeShape="RoundRectangle 12" HeightRequest="48" StrokeThickness="0">
                                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                    <Label Text="ÇIKIŞ" TextColor="White" FontAttributes="Bold" FontSize="12" />
                                    <Label Text="←" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenExitCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                            <Border Grid.Column="2" BackgroundColor="#5C6CD6" StrokeShape="RoundRectangle 12" HeightRequest="48" StrokeThickness="0">
                                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                    <Label Text="İADE" TextColor="White" FontAttributes="Bold" FontSize="12" />
                                    <Label Text="↺" TextColor="White" FontSize="16" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding OpenReturnCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding LoadDataCommand}">
                    <CollectionView ItemsSource="{Binding GroupedStocks}" SelectionMode="None">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ShelfGroup">
                            <VerticalStackLayout Padding="20,0,20,5">
                                <!-- Shelf Card -->
                                <Border StrokeThickness="1" Stroke="#D3E1FB" BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 15">
                                    <Border.Shadow>
                                        <Shadow Brush="#C6D9FB" Offset="0,2" Radius="6" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="50, *, Auto, Auto" VerticalOptions="Center">
                                        <!-- Shelf Icon -->
                                        <Border Grid.Column="0"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                BackgroundColor="#F2F7FF"
                                                Stroke="#D5E3FC"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="6">
                                            <Image Source="shelf_icon.jpg" Aspect="AspectFit" />
                                        </Border>

                                        <!-- Shelf Name -->
                                        <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                            <Label Text="{Binding ShelfName}" FontSize="16" FontAttributes="Bold" TextColor="#212121" />
                                            <Label Text="{Binding WarehouseName}" FontSize="11" TextColor="#9E9E9E" />
                                        </VerticalStackLayout>

                                        <!-- Product Count -->
                                        <Label Grid.Column="2" Text="{Binding ProductCount, StringFormat='{0} Kalem'}" 
                                               FontSize="14" TextColor="#0D47A1" VerticalOptions="Center" Margin="0,0,10,0" />

                                        <!-- Arrow -->
                                        <Label Grid.Column="3" Text="˃" FontSize="22" TextColor="#BDBDBD" VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                                    <Setter Property="Rotation" Value="90" />
                                                    <Setter Property="TextColor" Value="#0D47A1" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=ToggleShelfCommand}" CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>

                                <!-- Expanded Content (Raf Detayları) -->
                                <VerticalStackLayout IsVisible="{Binding IsExpanded}" Padding="10,10,10,5" Spacing="12">
                                     <BindableLayout.ItemsSource>
                                         <Binding Path="RafGroups" />
                                     </BindableLayout.ItemsSource>
                                     <BindableLayout.ItemTemplate>
                                         <DataTemplate x:DataType="models:RafGroup">
                                             <VerticalStackLayout Spacing="8">
                                                 <!-- Sub-shelf (Raf) Header -->
                                                 <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="5,2">
                                                     <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                                                         <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                             <BoxView Color="#0D47A1" WidthRequest="3" HeightRequest="15" CornerRadius="2" />
                                                             <Label Text="{Binding RafNo}" FontSize="12" FontAttributes="Bold" TextColor="#424242" />
                                                         </HorizontalStackLayout>
                                                         
                                                         <!-- Sub-arrow -->
                                                         <Label Grid.Column="1" Text="˃" FontSize="16" TextColor="#BDBDBD" VerticalOptions="Center">
                                                             <Label.Triggers>
                                                                 <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                                                     <Setter Property="Rotation" Value="90" />
                                                                     <Setter Property="TextColor" Value="#0D47A1" />
                                                                 </DataTrigger>
                                                             </Label.Triggers>
                                                         </Label>
                                                     </Grid>
                                                     <Border.GestureRecognizers>
                                                         <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=ToggleRafCommand}" CommandParameter="{Binding .}" />
                                                     </Border.GestureRecognizers>
                                                 </Border>

                                                 <!-- Products List -->
                                                 <VerticalStackLayout IsVisible="{Binding IsExpanded}" BindableLayout.ItemsSource="{Binding Products}" Spacing="8" Margin="10,0,0,5">
                                                     <BindableLayout.ItemTemplate>
                                                         <DataTemplate x:DataType="models:LocalStockItem">
                                                             <Border StrokeThickness="1" Stroke="#E1EAFB" BackgroundColor="#FAFCFF" Padding="12" StrokeShape="RoundRectangle 12">
                                                                 <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                                                     <Image Grid.Column="0" Source="{Binding IconSource}" WidthRequest="30" HeightRequest="30" />
                                                                     <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                                         <Label Text="{Binding MaterialName}" FontSize="13" FontAttributes="Bold" TextColor="#333" />
                                                                         <Label Text="{Binding Specification}" FontSize="10" TextColor="#757575" IsVisible="{Binding Specification, Converter={StaticResource IntToBoolConverter}, ConverterParameter=notempty}" />
                                                                     </VerticalStackLayout>
                                                                     <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                                                         <Label Text="{Binding Quantity}" FontSize="14" FontAttributes="Bold" TextColor="#0D47A1" HorizontalOptions="End" />
                                                                         <Label Text="{Binding Unit}" FontSize="9" TextColor="#9E9E9E" HorizontalOptions="End" />
                                                                     </VerticalStackLayout>
                                                                     <Grid.GestureRecognizers>
                                                                         <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=SelectStockCommand}" CommandParameter="{Binding .}" />
                                                                     </Grid.GestureRecognizers>
                                                                 </Grid>
                                                             </Border>
                                                         </DataTemplate>
                                                     </BindableLayout.ItemTemplate>
                                                 </VerticalStackLayout>
                                             </VerticalStackLayout>
                                         </DataTemplate>
                                     </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </Grid>

        <!-- Operation Modal Grid (Giriş/Çıkış Formu) -->
        <Grid BackgroundColor="#7A000000" IsVisible="{Binding IsOperationVisible}" Padding="16">
            <Border VerticalOptions="Center"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="520"
                    BackgroundColor="#F8F9FD"
                    HeightRequest="640"
                    Stroke="#D5E3FC"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    Padding="20">
                <Grid RowDefinitions="Auto, *, Auto">
                    <!-- Title & Close -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                        <Label Text="{Binding OperationTitle}" FontSize="20" FontAttributes="Bold" TextColor="#003d7a" VerticalOptions="Center" />
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 20" WidthRequest="40" HeightRequest="40" BackgroundColor="#EEE" StrokeThickness="0">
                            <Label Text="✕" FontSize="18" TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseOperationCommand}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Form Content -->
                    <ScrollView Grid.Row="1" Margin="0,8">
                        <VerticalStackLayout Spacing="18">
                            
                            <!-- Search/Select Section (Only for Entry) -->
                            <VerticalStackLayout Spacing="6" IsVisible="{Binding IsEntry}">
                                <Label Text="Malzeme Ara ve Seç" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,0">
                                    <Entry Placeholder="Malzeme adını buraya yazın..." 
                                           Text="{Binding MaterialSearchText}" 
                                           FontSize="14" HeightRequest="50" />
                                </Border>
                                
                                <!-- Search Results -->
                                <Border IsVisible="{Binding IsMaterialListVisible}" 
                                        BackgroundColor="White" 
                                        Stroke="#DDD" 
                                        StrokeThickness="1" 
                                        StrokeShape="RoundRectangle 12" 
                                        MaximumHeightRequest="200"
                                        Margin="0,2,0,0">
                                    <CollectionView ItemsSource="{Binding FilteredMaterials}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:MetadataItem">
                                                <VerticalStackLayout Padding="15" Spacing="2">
                                                    <Label Text="{Binding .}" FontSize="14" TextColor="#333" FontAttributes="Bold" />
                                                    <BoxView HeightRequest="1" Color="#F0F0F0" Margin="0,10,0,0" />
                                                    <VerticalStackLayout.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=SelectMaterialCommand}" CommandParameter="{Binding .}" />
                                                    </VerticalStackLayout.GestureRecognizers>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Border>

                                <!-- Selected Material Info -->
                                <Border IsVisible="{Binding SelectedMaterial, Converter={x:Static converters:NotNullToBoolConverter.Instance}}" 
                                        BackgroundColor="#E3F2FD" StrokeThickness="0" Padding="15,10" StrokeShape="RoundRectangle 8">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="✅" VerticalOptions="Center" />
                                        <Label Text="Seçildi:" FontSize="12" TextColor="#0077b6" FontAttributes="Bold" VerticalOptions="Center" />
                                        <Label Text="{Binding SelectedMaterial}" FontSize="12" TextColor="#0077b6" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Target Stock Info (Only for Exit/Return) -->
                            <Border IsVisible="{Binding IsExit}" BackgroundColor="#FFFEE3" Stroke="#FFE082" StrokeThickness="1" Padding="15" StrokeShape="RoundRectangle 12">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Grid.Column="0" WidthRequest="45" HeightRequest="45" StrokeShape="RoundRectangle 10" BackgroundColor="White" StrokeThickness="0">
                                        <Image Source="{Binding TargetStock.IconSource}" WidthRequest="25" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Margin="15,0,0,0" VerticalOptions="Center">
                                        <Label Text="{Binding TargetStock.MaterialName}" FontAttributes="Bold" TextColor="#856404" />
                                        <Label Text="{Binding TargetStock.Quantity, StringFormat='Mevcut Stok: {0}'}" FontSize="12" TextColor="#856404" Opacity="0.8" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <!-- Amount Section -->
                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15" IsVisible="{Binding IsEntry}">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="İşlem Miktarı" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,0">
                                        <Entry Text="{Binding OperationAmount}" Keyboard="Numeric" FontSize="18" FontAttributes="Bold" HeightRequest="55" />
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Start" VerticalOptions="End" Margin="0,0,0,5">
                                    <Label Text="{Binding OperationUnit}" FontSize="14" FontAttributes="Bold" TextColor="#003d7a" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Selection Fields (Entry) -->
                            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsEntry}">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Hedef Depo" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="10,0">
                                        <Picker ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}" ItemDisplayBinding="{Binding Ad}" FontSize="14" HeightRequest="50" Title="Seçin..." />
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Raf Seçin" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="10,0">
                                        <Picker ItemsSource="{Binding Shelves}" SelectedItem="{Binding SelectedShelf}" ItemDisplayBinding="{Binding Ad}" FontSize="14" HeightRequest="50" Title="Seçin..." />
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <!-- Additional Info (Entry) -->
                            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsEntry}">
                                <VerticalStackLayout Spacing="6" IsVisible="{Binding IsRafNoVisible}">
                                    <Label Text="Raf No" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,0">
                                        <Entry Text="{Binding RafNo}" Placeholder="Örn: A-1" FontSize="14" HeightRequest="50" />
                                    </Border>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Firma (Gönderen)" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="10,0">
                                        <Picker ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}" ItemDisplayBinding="{Binding FirmaAdi}" FontSize="14" HeightRequest="50" Title="Firma Seç..." />
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <!-- Dynamic Fields -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding DynamicFields}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:FormAlan">
                                        <VerticalStackLayout Spacing="6" Margin="0,0,0,10">
                                            <Label Text="{Binding AlanAdi}" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                            <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,0">
                                                <Grid>
                                                    <Entry Text="{Binding Value}" FontSize="14" HeightRequest="50" IsVisible="{Binding Options.Count, Converter={StaticResource IntToBoolConverter}, ConverterParameter=invert}" />
                                                    <Picker ItemsSource="{Binding Options}" SelectedItem="{Binding Value}" FontSize="14" HeightRequest="50" IsVisible="{Binding Options.Count, Converter={StaticResource IntToBoolConverter}}" />
                                                </Grid>
                                            </Border>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                             <!-- Exit Process Specific Fields -->
                            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsExit}">
                                <!-- Material Selection for Exit -->
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Çıkış Yapılacak Ürünü Seçin" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,0">
                                        <Entry Placeholder="Ürün ara..." Text="{Binding ExitMaterialSearchText}" FontSize="14" HeightRequest="50" />
                                    </Border>

                                    <!-- Available Stocks Result -->
                                    <Border IsVisible="{Binding ExitAvailableStocks.Count, Converter={StaticResource IntToBoolConverter}}" 
                                            BackgroundColor="White" Stroke="#DDD" StrokeThickness="1" StrokeShape="RoundRectangle 12" MaximumHeightRequest="150"
                                            ZIndex="10">
                                        <CollectionView ItemsSource="{Binding ExitAvailableStocks}">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="models:LocalStockItem">
                                                    <Grid Padding="15,10" ColumnDefinitions="*, Auto">
                                                        <VerticalStackLayout Grid.Column="0">
                                                            <Label Text="{Binding MaterialName}" FontAttributes="Bold" FontSize="13" />
                                                            <Label Text="{Binding WarehouseName, StringFormat='Depo: {0}'}" FontSize="11" TextColor="Gray" />
                                                        </VerticalStackLayout>
                                                        <Label Grid.Column="1" Text="{Binding Quantity, StringFormat='{0} Adet'}" TextColor="#0077b6" FontAttributes="Bold" VerticalOptions="Center" />
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=SelectExitStockCommand}" CommandParameter="{Binding .}" />
                                                        </Grid.GestureRecognizers>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Exit Detail Card -->
                                <Border IsVisible="{Binding TargetStock, Converter={x:Static converters:NotNullToBoolConverter.Instance}}" 
                                        Padding="20" BackgroundColor="#F0F7FF" Stroke="#BEE3F8" StrokeThickness="1" StrokeShape="RoundRectangle 20" Margin="0,5">
                                    <VerticalStackLayout Spacing="15">
                                        <HorizontalStackLayout Spacing="10">
                                            <Border WidthRequest="35" HeightRequest="35" StrokeShape="RoundRectangle 8" BackgroundColor="White" StrokeThickness="0">
                                                <Image Source="{Binding TargetStock.IconSource}" WidthRequest="20" />
                                            </Border>
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label Text="{Binding TargetStock.MaterialName}" FontAttributes="Bold" TextColor="#003d7a" FontSize="14" />
                                                <Label Text="{Binding TargetStock.Quantity, StringFormat='Mevcut: {0}'}" FontSize="11" TextColor="#2B6CB0" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>

                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="Çıkış Miktarı" FontSize="11" TextColor="#4A5568" FontAttributes="Bold" />
                                                <Border StrokeThickness="1" Stroke="#CBD5E0" BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="12,0">
                                                    <Entry Text="{Binding OperationAmount}" Keyboard="Numeric" Placeholder="0" HeightRequest="45" FontSize="16" FontAttributes="Bold" />
                                                </Border>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding OperationUnit}" VerticalOptions="End" Margin="0,0,0,12" FontAttributes="Bold" TextColor="#4A5568" />
                                        </Grid>

                                        <Grid ColumnDefinitions="120, *" ColumnSpacing="15">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="Çıkış Türü" FontSize="11" TextColor="#4A5568" FontAttributes="Bold" />
                                                <Border StrokeThickness="1" Stroke="#CBD5E0" BackgroundColor="White" StrokeShape="RoundRectangle 10">
                                                    <Picker SelectedItem="{Binding ExitType}" HeightRequest="45" FontSize="13">
                                                        <Picker.ItemsSource>
                                                            <x:Array Type="{x:Type x:String}">
                                                                <x:String>Sarf</x:String>
                                                                <x:String>Demirbaş</x:String>
                                                            </x:Array>
                                                        </Picker.ItemsSource>
                                                    </Picker>
                                                </Border>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4" IsVisible="{Binding IsDemirbas}">
                                                <Label Text="Personel" FontSize="11" TextColor="#4A5568" FontAttributes="Bold" />
                                                <Border StrokeThickness="1" Stroke="#CBD5E0" BackgroundColor="White" StrokeShape="RoundRectangle 10">
                                                    <Picker ItemsSource="{Binding Personnel}" SelectedItem="{Binding SelectedPersonnel}"
                                                            ItemDisplayBinding="{Binding AdSoyad}" HeightRequest="45" FontSize="13" Title="Seçin..." />
                                                </Border>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Button Text="SEPETE EKLE" Command="{Binding AddToBasketCommand}" 
                                                BackgroundColor="#0077b6" TextColor="White" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" Margin="0,5,0,0" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Exit Basket -->
                                <VerticalStackLayout Spacing="10" IsVisible="{Binding ExitBasket.Count, Converter={StaticResource IntToBoolConverter}}" Margin="0,10,0,0">
                                    <Label Text="Sepettekiler" FontAttributes="Bold" TextColor="#003d7a" FontSize="14" />
                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding ExitBasket}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:ExitCartItem">
                                                <Border StrokeThickness="0" Padding="15" Margin="0,0,0,10" StrokeShape="RoundRectangle 15" BackgroundColor="White">
                                                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                            <Label Text="{Binding Stock.MaterialName}" FontAttributes="Bold" FontSize="14" />
                                                            <HorizontalStackLayout Spacing="10">
                                                                <Label Text="{Binding Amount, StringFormat='{0} Adet'}" FontSize="12" TextColor="#0077b6" FontAttributes="Bold" />
                                                                <Label Text="{Binding ExitType}" FontSize="12" TextColor="Gray" />
                                                            </HorizontalStackLayout>
                                                        </VerticalStackLayout>
                                                        <Button Grid.Column="1" Text="" FontFamily="FontAwesomeSolid" FontSize="18" TextColor="#E53E3E" BackgroundColor="Transparent" 
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=RemoveFromBasketCommand}" 
                                                                CommandParameter="{Binding .}" WidthRequest="40" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>

                            <!-- Return Specific Fields -->
                            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsReturn}">
                                <VerticalStackLayout Spacing="6" IsVisible="{Binding TargetStock, Converter={x:Static converters:NotNullToBoolConverter.Instance}, ConverterParameter=invert}">
                                    <Label Text="İade Edilecek Ürünü Seçin" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                    <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,0">
                                        <Entry Placeholder="Ürün ara..." Text="{Binding ExitMaterialSearchText}" FontSize="14" HeightRequest="50" />
                                    </Border>
                                    <Border IsVisible="{Binding ExitAvailableStocks.Count, Converter={StaticResource IntToBoolConverter}}" 
                                            BackgroundColor="White" Stroke="#DDD" StrokeThickness="1" StrokeShape="RoundRectangle 12" MaximumHeightRequest="150">
                                        <CollectionView ItemsSource="{Binding ExitAvailableStocks}">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="models:LocalStockItem">
                                                    <Grid Padding="15,10" ColumnDefinitions="*, Auto">
                                                        <VerticalStackLayout Grid.Column="0">
                                                            <Label Text="{Binding MaterialName}" FontAttributes="Bold" FontSize="13" />
                                                            <Label Text="{Binding WarehouseName, StringFormat='Depo: {0}'}" FontSize="11" TextColor="Gray" />
                                                        </VerticalStackLayout>
                                                        <Label Grid.Column="1" Text="{Binding Quantity, StringFormat='{0} Adet'}" TextColor="#0077b6" FontAttributes="Bold" VerticalOptions="Center" />
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryViewModel}}, Path=SelectExitStockCommand}" CommandParameter="{Binding .}" />
                                                        </Grid.GestureRecognizers>
                                                    </Grid>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </Border>
                                </VerticalStackLayout>

                                <Border IsVisible="{Binding TargetStock, Converter={x:Static converters:NotNullToBoolConverter.Instance}}" 
                                        Padding="20" BackgroundColor="#F0F7FF" Stroke="#BEE3F8" StrokeThickness="1" StrokeShape="RoundRectangle 20">
                                    <VerticalStackLayout Spacing="15">
                                        <HorizontalStackLayout Spacing="10">
                                            <Border WidthRequest="35" HeightRequest="35" StrokeShape="RoundRectangle 8" BackgroundColor="White" StrokeThickness="0">
                                                <Image Source="{Binding TargetStock.IconSource}" WidthRequest="20" />
                                            </Border>
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label Text="{Binding TargetStock.MaterialName}" FontAttributes="Bold" TextColor="#003d7a" FontSize="14" />
                                                <Label Text="{Binding TargetStock.WarehouseName, StringFormat='Depo: {0}'}" FontSize="11" TextColor="#2B6CB0" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>

                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="İade Miktarı" FontSize="11" TextColor="#4A5568" FontAttributes="Bold" />
                                                <Border StrokeThickness="1" Stroke="#CBD5E0" BackgroundColor="White" StrokeShape="RoundRectangle 10" Padding="12,0">
                                                    <Entry Text="{Binding OperationAmount}" Keyboard="Numeric" Placeholder="0" HeightRequest="45" FontSize="16" FontAttributes="Bold" />
                                                </Border>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="{Binding OperationUnit}" VerticalOptions="End" Margin="0,0,0,12" FontAttributes="Bold" TextColor="#4A5568" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>

                            <!-- Note Section -->
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Açıklama / Not" FontSize="12" FontAttributes="Bold" TextColor="#666" Margin="2,0" />
                                <Border StrokeThickness="1" Stroke="#DDD" BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="15,5">
                                    <Editor Text="{Binding OperationNote}" AutoSize="TextChanges" FontSize="14" Placeholder="İşlem ile ilgili notlar..." MinimumHeightRequest="80" />
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Form Buttons -->
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15" Padding="0,10,0,0">
                        <Button Grid.Column="0" Text="İPTAL" Command="{Binding CloseOperationCommand}" BackgroundColor="#EEE" TextColor="#666" CornerRadius="15" HeightRequest="55" FontAttributes="Bold" />
                        <Button Grid.Column="1" Text="İŞLEMİ KAYDET" Command="{Binding SaveOperationCommand}" BackgroundColor="#003d7a" TextColor="White" CornerRadius="15" HeightRequest="55" FontAttributes="Bold" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Custom Navigation Bar -->
        <controls:CustomNavigationBar CurrentPage="Stoklar" VerticalOptions="End" ZIndex="100" />
    </Grid>
</ContentPage>
