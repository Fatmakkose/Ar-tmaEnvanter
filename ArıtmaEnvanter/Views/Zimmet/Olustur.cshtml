@model ArıtmaEnvanter.Models.Entities.Zimmet
@{
    ViewData["Title"] = "Yeni Zimmet Ver";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-clipboard-plus me-2" style="color:#00a8e8;"></i>Yeni Zimmet Ver</h2>
        <p>Personele ürün/alet zimmetleyin</p>
    </div>
    <a asp-action="Index" class="btn-outline-clear"><i class="bi bi-arrow-left"></i> Listeye Dön</a>
</div>

<div class="form-card">
    <div class="form-card-head">
        <i class="bi bi-clipboard-check"></i>
        <h5>Zimmet Bilgileri</h5>
    </div>
    <div class="form-card-body">
        <form method="post" asp-controller="Zimmet" asp-action="Olustur">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Personel <span style="color:#ef4444;">*</span></label>
                <select asp-for="PersonelId" class="form-select" required>
                    <option value="">— Personel Seçin —</option>
                    @foreach (var p in ViewBag.Personeller)
                    {
                        if (ViewBag.SeciliPersonelId != null && ViewBag.SeciliPersonelId == p.Id)
                        {
                            <option value="@p.Id" selected>@p.AdSoyad</option>
                        }
                        else
                        {
                            <option value="@p.Id">@p.AdSoyad</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Ürün / Alet <span style="color:#ef4444;">*</span></label>
                <select asp-for="MalzemeId" class="form-select" required>
                    <option value="">— Ürün Seçin —</option>
                    @foreach (var u in ViewBag.Malzemeler)
                    {
                        <option value="@u.Id">@u.Ad</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Notlar</label>
                <textarea asp-for="Notlar" class="form-control" rows="3"
                          placeholder="Zimmetle ilgili notlar..."></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-maski">
                    <i class="bi bi-check-lg"></i> Zimmeti Kaydet
                </button>
                <a asp-action="Index" class="btn-outline-clear">İptal</a>
            </div>
        </form>
    </div>
</div>