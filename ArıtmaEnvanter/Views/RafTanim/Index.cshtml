@model List<ArıtmaEnvanter.Models.Entities.RafTanim>
@{
    ViewData["Title"] = "Raf Tanımı";
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-layout-three-columns me-2" style="color:var(--accent);"></i>Raf Tanımı</h2>
        <p>Depo raflarını tanımlayın ve yönetin.</p>
    </div>
    <div class="header-actions">
        <a asp-action="Ekle" class="btn-cyan">
            <i class="bi bi-plus-lg"></i> Yeni Raf Ekle
        </a>
    </div>
</div>

@if (TempData["Basarili"] != null)
{
    <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> @TempData["Basarili"]</div>
}

@if (!Model.Any())
{
    <div class="data-card">
        <div class="data-card-head">
            <h6><i class="bi bi-layout-three-columns"></i> Raf Listesi <span class="record-count">0 kayıt</span></h6>
        </div>
        <div class="empty-state">
            <i class="bi bi-layout-three-columns" style="font-size:48px; color:var(--accent); opacity:0.4;"></i>
            <p class="mt-3" style="font-size:15px; font-weight:600; color:var(--text-muted);">Henüz raf tanımlanmamış</p>
            <p style="font-size:13px; color:var(--text-muted);">Yeni Raf Ekle butonuna tıklayarak depo raflarınızı tanımlayabilirsiniz.</p>
        </div>
    </div>
}
else
{
    <div class="data-card">
        <div class="data-card-head">
            <h6><i class="bi bi-layout-three-columns"></i> Raf Listesi <span class="record-count">@Model.Count kayıt</span></h6>
        </div>
        <div style="overflow-x:auto;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Raf Adı</th>
                        <th>Sorumlu Personel</th>
                        <th>İletişim</th>

                        <th>Oluşturma Tarihi</th>
                        <th>Durum</th>
                        <th style="text-align:right;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var raf in Model)
                    {
                        <tr>
                            <td style="font-weight:700; color:var(--primary);">
                                <a href="/RafTanim/Stoklar/@raf.Id" style="text-decoration:none; color:inherit; display:block;" title="Tıkla ve raftaki ürünleri gör">
                                    <i class="bi bi-box-seam me-1"></i> @raf.Ad
                                </a>
                            </td>
                            <td>@raf.SorumluPersonel</td>
                            <td>@(raf.Iletisim ?? "—")</td>

                            <td style="font-size:12px; color:var(--text-muted);">@raf.OlusturmaTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                 @if (raf.AktifMi) 
                                {
                                    <span class="badge" style="background-color: #d1fae5; color: #065f46; padding: 5px 10px; border-radius: 6px; font-size: 12px; font-weight: 600;">
                                        <i class="bi bi-check-circle-fill me-1"></i> Aktif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color: #fee2e2; color: #991b1b; padding: 5px 10px; border-radius: 6px; font-size: 12px; font-weight: 600;">
                                        <i class="bi bi-x-circle-fill me-1"></i> Pasif
                                    </span>
                                }
                            </td>
                            <td style="text-align:right;">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Duzenle" asp-route-id="@raf.Id" class="btn-edit">
                                        <i class="bi bi-pencil"></i> Düzenle
                                    </a>
                                    <form asp-action="Sil" asp-route-id="@raf.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Bu rafı silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-del"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
