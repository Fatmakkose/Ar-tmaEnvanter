@model ArıtmaEnvanter.Models.ViewModels.PoliCizelgeViewModel
@{
    ViewData["Title"] = "Poli Tüketim Çizelgesi";
    string[] Aylar = { "OCAK", "ŞUBAT", "MART", "NİSAN", "MAYIS", "HAZİRAN", "TEMMUZ", "AĞUSTOS", "EYLÜL", "EKİM", "KASIM", "ARALIK" };
}

<style>
    :root {
        --poly-navy: #1e3a5f;
        --poly-blue: #0ea5e9;
        --poly-light: #f8fafc;
        --poly-border: #e2e8f0;
        --poly-success: #10b981;
    }

    body {
        background-color: #f1f5f9;
        font-family: 'Inter', sans-serif;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border: 1px solid var(--poly-border);
        border-radius: 16px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.02);
        transition: transform 0.2s, box-shadow 0.2s;
        margin-bottom: 24px;
        overflow: hidden;
    }

    .premium-header {
        background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);
        color: white;
        padding: 30px;
        border-radius: 16px;
        margin-bottom: 30px;
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    .header-logo {
        height: 70px;
        filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.2));
    }

    .header-title-group {
        text-align: center;
        flex: 1;
    }

    .header-title-group h1 {
        font-size: 24px;
        font-weight: 800;
        letter-spacing: 1px;
        margin-bottom: 5px;
        text-transform: uppercase;
    }

    .header-title-group p {
        font-size: 14px;
        opacity: 0.8;
        letter-spacing: 2px;
        margin: 0;
    }

    .stat-badge {
        font-size: 12px;
        padding: 6px 14px;
        border-radius: 50px;
        font-weight: 600;
    }

    .badge-input { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .badge-weight { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }

    .matrix-table-container {
        overflow-x: auto;
        padding: 20px;
    }

    .matrix-btn {
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .matrix-btn:hover {
        transform: translateY(-2px);
    }

    .control-panel {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

   
    .btn-custom {
        border-radius: 10px;
        padding: 8px 20px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-custom-outline {
        border: 2px solid #cbd5e1;
        color: #64748b;
        background: white;
    }

    .btn-custom-outline:hover {
        background: #f1f5f9;
        border-color: #94a3b8;
    }

    .btn-custom-primary {
        background: var(--poly-navy);
        color: white;
        border: none;
    }

    .btn-custom-primary:hover {
        background: #162e4a;
        transform: translateY(-1px);
    }
</style>

<div class="control-panel">
    <a asp-action="Index" class="btn-custom btn-custom-outline">
        <i class="bi bi-chevron-left"></i> Geri Dön
    </a>
    <h4 class="mb-0 fw-bold" style="color:var(--poly-navy)">
        <i class="bi bi-graph-up-arrow me-2"></i>POLİ TÜKETİM MATRİSİ (@Model.Yil@(Model.Ay.HasValue ? $" / {Aylar[Model.Ay.Value - 1]}" : ""))
    </h4>
    <form method="get" class="d-flex gap-2">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0"><i class="bi bi-calendar3"></i></span>
            <select name="ay" class="form-select border-start-0 border-end-0" style="width:130px; font-weight:600;">
                <option value="">Tüm Yıl</option>
                @for (int i = 0; i < 12; i++)
                {
                    <!option value="@(i + 1)" @(Model.Ay == i + 1 ? "selected" : "")>@Aylar[i]</!option>
                }
            </select>
            <input type="number" name="yil" value="@Model.Yil" class="form-control border-start-0" style="width:100px; font-weight:600;" />
            <button type="submit" class="btn btn-primary fw-bold" style="background:var(--poly-navy)">Filtrele</button>
        </div>
    </form>
</div>

<div class="premium-header">
    <img src="/images/image.png" class="header-logo" alt="Logo" />
    <div class="header-title-group">
        <h1>İleri Biyolojik Atıksu Arıtma Tesisi</h1>
        <p>Polimer Tüketim & Teslimat Yönetimi</p>
    </div>
    <img src="/images/image copy.png" class="header-logo" alt="Logo" />
</div>

<div class="row">
   
    <div class="col-lg-5">
        <div class="glass-card">
            <div class="p-3 border-bottom bg-light d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2"></i>Teslimat Geçmişi</h6>
                <span class="badge" style="background:var(--poly-navy)">@Model.Girisler.Count Kayıt</span>
            </div>
            <div style="max-height: 500px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0" style="font-size:13px;">
                    <thead class="bg-light sticky-top">
                        <tr>
                            <th class="ps-3">Tarih</th>
                            <th>Miktar</th>
                            <th>Firma / Not</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in Model.Girisler.OrderByDescending(x => x.Tarih))
                        {
                            <tr>
                                <td class="ps-3 fw-bold">@g.Tarih.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <div class="d-flex flex-column gap-1">
                                        <span class="stat-badge badge-input">@g.Adet.ToString("0.##") Bidon</span>
                                        <span class="stat-badge badge-weight">@g.Kg.ToString("0.#") KG</span>
                                    </div>
                                </td>
                                <td><span class="text-muted">@(g.Aciklama ?? "—")</span></td>
                            </tr>
                        }
                        @if (!Model.Girisler.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                    Kayıtlı teslimat bulunamadı.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    
    <div class="col-lg-7">
        <div class="glass-card">
            <div class="p-3 border-bottom bg-light">
                <h6 class="mb-0 fw-bold"><i class="bi bi-grid-3x3 me-2"></i>Aylık Tüketim Özeti</h6>
            </div>
            <div class="p-4 text-center">
                <div class="alert alert-info border-0 shadow-sm" style="border-radius:12px;">
                    <i class="bi bi-info-circle-fill me-2"></i> Tüketim verileri günlük olarak otomatik kaydedilmektedir.
                </div>
                
                <div class="row g-4 mt-2">
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 border bg-white shadow-sm">
                            <small class="text-muted d-block mb-1">Toplam Giriş (Yıllık)</small>
                            <h4 class="fw-bold mb-0 text-primary">@Model.Girisler.Sum(g => g.Kg).ToString("N0") <small>KG</small></h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 border bg-white shadow-sm">
                            <small class="text-muted d-block mb-1">Toplam Tüketim</small>
                            <h4 class="fw-bold mb-0 text-danger">@Model.Tuketimler.Sum(t => t.Kg).ToString("N0") <small>KG</small></h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        @{
                            decimal devir = Model.Devir?.DevredenKg ?? 0;
                            decimal kalan = devir + Model.Girisler.Sum(g => g.Kg) - Model.Tuketimler.Sum(t => t.Kg);
                        }
                        <div class="p-3 rounded-4 border bg-white shadow-sm" style="border-left: 4px solid var(--poly-success) !important;">
                            <small class="text-muted d-block mb-1">Mevcut Stok</small>
                            <h4 class="fw-bold mb-0 text-success">@kalan.ToString("N0") <small>KG</small></h4>
                        </div>
                    </div>
                </div>
            </div>
            
           
            <div class="p-3 border-top bg-light text-center">
                <button class="btn btn-dark fw-bold btn-sm rounded-pill px-4">
                    <i class="bi bi-table me-2"></i>Tam Tüketim Tablosunu Görüntüle
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
       
        document.querySelectorAll('.glass-card').forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                card.style.transition = 'all 0.5s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });
    </script>
}
