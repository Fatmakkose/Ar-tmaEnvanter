@model List<ArıtmaEnvanter.Models.ViewModels.RafStokViewModel>
@{
    ViewData["Title"] = ViewBag.RafAd + " Stokları";
}

<style>
    .raf-container {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #fff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border: 1px solid #e2e8f0;
    }
    
    .raf-header-box {
        background-color: #1e3a8a; 
        color: white;
        text-align: center;
        padding: 15px;
        font-weight: 800;
        font-size: 26px;
        letter-spacing: 2px;
        text-transform: uppercase;
        border-radius: 8px 8px 0 0;
        margin-bottom: 0;
    }
    
    .raf-subheader-box {
        background-color: #fef3c7; 
        color: #1e3a8a;
        text-align: center;
        padding: 15px;
        font-weight: 700;
        line-height: 1.5;
        font-size: 15px;
        border: 1px solid #1e3a8a;
        border-top: none;
        border-radius: 0 0 8px 8px;
        margin-bottom: 30px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .raf-table-wrapper {
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #cbd5e1;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .raf-table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
        background: #fff;
    }

    .raf-table th, .raf-table td {
        padding: 14px 16px;
        vertical-align: middle;
        font-size: 14px;
        border-bottom: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
    }

    .raf-table th:last-child, .raf-table td:last-child {
        border-right: none;
    }

    .raf-table th {
        background-color: #fcd34d; 
        color: #1e293b;
        text-align: center;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 0.5px;
    }

    .raf-table th.kalan-header {
        background-color: #dc2626; 
        color: #ffffff;
    }
    
    .raf-table th.islem-header {
        background-color: #f8fafc;
        color: #64748b;
        border-bottom: 2px solid #e2e8f0;
    }

    .raf-table tbody tr:nth-child(even) {
        background-color: #f8fafc;
    }
    
    .raf-table tbody tr:hover {
        background-color: #f1f5f9;
        transition: background-color 0.2s ease;
    }

    .raf-table td {
        color: #334155;
    }
    
    .raf-table td.center-col {
        text-align: center;
        font-weight: 600;
        color: #0f172a;
    }

    .raf-table td.kalan-col {
        background-color: #fee2e2;
        color: #dc2626;
        text-align: center;
        font-weight: 800;
        font-size: 15px;
    }
    
    .btn-delete-row {
        background-color: transparent;
        color: #ef4444;
        border: 1px solid #fca5a5;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }
    
    .btn-delete-row:hover {
        background-color: #ef4444;
        color: white;
        border-color: #ef4444;
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold fs-3 text-dark"><i class="bi bi-box-seam me-2" style="color:#2563eb;"></i>@ViewBag.RafAd Stok Detayları</h2>
        <p class="text-muted mb-0">Seçilen raftaki tüm ürünlerin güncel stok dökümü.</p>
    </div>
    <a href="/RafTanim/Index" class="btn btn-light border shadow-sm fw-bold">
        <i class="bi bi-arrow-left me-1"></i> Raflara Dön
    </a>
</div>

@if (TempData["Basarili"] != null)
{
    <div class="alert alert-success border-0 shadow-sm d-flex align-items-center p-3 mb-4 rounded-3" style="background:#f0fdf4;">
        <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
        <div class="fw-bold text-success">@TempData["Basarili"]</div>
    </div>
}

<div class="raf-container">
    <div class="raf-header-box">MASKİ</div>
    <div class="raf-subheader-box">
        ARITMA TESİSLERİ DAİRE BAŞKANLIĞI<br>
        İLERİ BİYOLOJİK ARITMA TESİSİ<br>
        DEPO MALZEME LİSTESİ
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info border-0 shadow-sm d-flex align-items-center p-4 mt-2" style="background: #eff6ff; border-radius: 12px;">
            <i class="bi bi-info-circle-fill text-primary me-3" style="font-size: 32px;"></i>
            <div class="flex-grow-1">
                <h5 class="fw-bold mb-1" style="color: #1e3a8a;">Bu Rafta Kayıtlı Ürün Bulunamadı</h5>
                <p class="mb-0" style="color: #3b82f6; font-size: 14px;">
                    Seçmiş olduğunuz <strong>@ViewBag.RafAd</strong> içerisine henüz herhangi bir ürün stoklanmamış. Yeni stok girişi yaparken raf numarası belirterek bu listeyi doldurabilirsiniz.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="raf-table-wrapper">
            <table class="raf-table">
                <thead>
                    <tr>
                        <th style="width: 15%;">RAF NUMARASI</th>
                        <th style="width: 45%; text-align: left; padding-left: 16px;">ÜRÜN ADI</th>
                        <th style="width: 10%;">ADET (GİREN)</th>
                        <th style="width: 10%;">VERİLEN (ÇIKAN)</th>
                        <th style="width: 10%;" class="kalan-header">KALAN</th>
                        <th style="width: 10%;" class="islem-header">İŞLEM</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td class="center-col">@s.RafNo</td>
                            <td style="font-weight: 600;">@s.UrunAdi</td>
                            <td class="center-col">@s.Adet.ToString("0.##")</td>
                            <td class="center-col" style="color: #64748b;">
                                @(s.Verilen > 0 ? s.Verilen.ToString("0.##") : "-")
                            </td>
                            <td class="kalan-col">@s.Kalan.ToString("0.##")</td>
                            <td class="center-col" style="background: #fff;">
                                <form asp-action="StokSil" asp-controller="RafTanim" method="post" onsubmit="return confirm('Uyarı: Bu stok kaydını tamamen silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="stokId" value="@s.StokId" />
                                    <input type="hidden" name="rafId" value="@ViewBag.RafId" />
                                    <button type="submit" class="btn-delete-row" title="Hatalı kaydı sil">
                                        <i class="bi bi-trash3-fill"></i> Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
