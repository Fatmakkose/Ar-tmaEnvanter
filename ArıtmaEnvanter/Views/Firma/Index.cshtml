@model IEnumerable<ArıtmaEnvanter.Models.Entities.Firma>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0 text-primary"><i class="bi bi-buildings me-2"></i>Firma Tanımları</h2>
    <a asp-action="Ekle" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Yeni Firma Ekle
    </a>
</div>

@if (TempData["Basarili"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Basarili"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Firma Adı</th>
                        <th>İlgili Kişi Ad Soyad</th>
                        <th>İletişim Numarası</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">
                                <i class="bi bi-info-circle me-2"></i> Henüz firma tanımı yapılmamış.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">
                                    @item.FirmaAdi
                                </td>
                                <td>@item.IlgiliKisiAdSoyad</td>
                                <td>@(string.IsNullOrEmpty(item.IletisimNumarasi) ? "-" : item.IletisimNumarasi)</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Duzenle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <form asp-action="Sil" asp-route-id="@item.Id" method="post" class="d-inline-block" onsubmit="return confirm('@item.FirmaAdi firmasını silmek istediğinize emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                                <i class="bi bi-trash3-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
