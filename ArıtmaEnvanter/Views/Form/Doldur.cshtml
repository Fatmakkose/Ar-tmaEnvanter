@model ArıtmaEnvanter.Models.Entities.FormSablon
@{
    ViewData["Title"] = Model.Baslik;
}

<div class="page-header">
    <div>
        <h2><i class="bi bi-plus-square me-2" style="color:#00a8e8;"></i>@Model.Baslik Girişi</h2>
        <p>@(Model.Aciklama ?? "Ürün bilgilerini girin ve envantere kaydedin")</p>
    </div>
    <a asp-action="Index" class="btn-outline-clear"><i class="bi bi-arrow-left"></i> Geri Dön</a>
</div>

@if (TempData["Basarili"] != null)
{
    <div class="alert-ok"><i class="bi bi-check-circle-fill"></i> @TempData["Basarili"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="alert-err"><i class="bi bi-exclamation-circle-fill"></i> @TempData["Hata"]</div>
}

<form method="post" asp-controller="Form" asp-action="Doldur" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()

    
    <div
        style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;margin-bottom:16px;border-top:6px solid #003d7a;padding:24px;">
        <div style="font-size:22px;font-weight:700;color:#003d7a;">@Model.Baslik</div>
        @if (!string.IsNullOrEmpty(Model.Aciklama))
        {
            <div style="font-size:14px;color:#64748b;margin-top:6px;">@Model.Aciklama</div>
        }
        <div style="font-size:12px;color:#94a3b8;margin-top:8px;">
            <i class="bi bi-info-circle"></i> * işaretli alanlar zorunludur. Her ürün için ayrı satır ekleyebilirsiniz.
        </div>
    </div>

    
    <div id="satirlar">
       
    </div>

    
    <div style="text-align:center;margin:16px 0;">
        <button type="button" onclick="satirEkle()"
            style="background:#fff;border:2px dashed #00a8e8;color:#003d7a;padding:12px 32px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;width:100%;transition:all 0.2s;">
            <i class="bi bi-plus-circle"></i> Yeni Ürün Satırı Ekle
        </button>
    </div>

    <div class="form-actions-bottom" style="display:flex;justify-content:flex-end;gap:10px;margin-top:8px;">
        <a asp-action="Index" class="btn-outline-clear">İptal</a>
        <button type="submit" class="btn-maski" style="padding:12px 28px;">
            <i class="bi bi-check-all"></i> Varlığı Envantere Kaydet
        </button>
    </div>
</form>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/quagga/0.12.1/quagga.min.js"></script>
    <style>
        @@media (max-width: 575.98px) {
            .form-row-item {
                padding: 12px 16px !important;
            }

            .form-actions-bottom {
                flex-direction: column-reverse;
                width: 100%;
            }

            .form-actions-bottom>button,
            .form-actions-bottom>a {
                width: 100%;
                text-align: center;
                justify-content: center;
            }

            #barcodeModal>div {
                width: 95% !important;
                padding: 12px !important;
            }

            #reader {
                height: 250px !important;
            }
        }

        .select2-container--default .select2-selection--single {
            height: 38px;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 4px 6px;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 36px;
        }

        .select2-container--default .select2-selection--single:focus {
            outline: none;
            border-color: #003d7a;
            box-shadow: 0 0 0 3px rgba(0, 61, 122, 0.1);
        }
    </style>
    <script>
        const alanlar = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Alanlar.OrderBy(a => a.Sira).Select(a => new
        {
         id = a.Id,
         alanAdi = a.AlanAdi,
         alanTipi = a.AlanTipi,
         secenekler = a.Secenekler,
         gerekli = a.Gerekli
        })
        ));

        const personelListesi = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ViewBag.Personeller != null
        ? (object)((IEnumerable<ArıtmaEnvanter.Models.Entities.Personel>)ViewBag.Personeller)
        .GroupBy(p => p.Birim?.Ad ?? "Birimsiz")
        .OrderBy(g => g.Key)
        .Select(g => new { birim = g.Key, kisiler = g.OrderBy(p => p.AdSoyad).Select(p => new { ad = p.AdSoyad, unvan = p.Unvan }) })
        : (object)new List<object>()
        ));

        const birimListesi = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ViewBag.Birimler != null
        ? (object)((IEnumerable<ArıtmaEnvanter.Models.Entities.Birim>)ViewBag.Birimler)
        .GroupBy(b => b.UstBirim?.Ad ?? "Ana Birimler")
        .OrderBy(g => g.Key)
        .Select(g => new { grup = g.Key, birimler = g.OrderBy(b => b.Ad).Select(b => new { ad = b.Ad }) })
        : (object)new List<object>()
        ));

        const urunListesi = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ViewBag.Urunler != null
        ? (object)((IEnumerable<ArıtmaEnvanter.Models.Entities.Malzeme>)ViewBag.Urunler)
        .GroupBy(u => u.Kategori?.Ad ?? "Kategorisiz")
        .OrderBy(g => g.Key)
        .Select(g => new { grup = g.Key, urunler = g.OrderBy(u => u.UrunTuru).Select(u => new { tur = u.UrunTuru, seri = u.SeriNo, birim = u.Birim?.Ad }) })
        : (object)new List<object>()
        ));

        const lokasyonListesi = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        ViewBag.Lokasyonlar != null
        ? (object)((IEnumerable<ArıtmaEnvanter.Models.Entities.Lokasyon>)ViewBag.Lokasyonlar)
        .Select(l => new { id = l.Id, birim = l.Birim?.Ad ?? "Belirtilmemiş", kat = l.Kat, oda = l.OdaNo })
        : (object)new List<object>()
        ));

        let satirSayisi = 0;

        function satirEkle() {
            satirSayisi++;
            const satirNo = satirSayisi;
            const container = document.getElementById('satirlar');

            const satirDiv = document.createElement('div');
            satirDiv.id = `satir_${satirNo}`;
            satirDiv.className = 'form-row-item';
            satirDiv.style.cssText = 'background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:20px 24px;margin-bottom:12px;position:relative;';

            let html = `
                                                                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;padding-bottom:12px;border-bottom:2px solid #003d7a;">
                                                                                    <span style="font-size:14px;font-weight:700;color:#003d7a;">
                                                                                        <i class="bi bi-box-seam"></i> Ürün #${satirNo}
                                                                                    </span>
                                                                                    ${satirNo > 1 ? `<button type="button" onclick="satirSil('satir_${satirNo}')"
                                                                                        style="background:#fff1f2;color:#dc2626;border:none;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;">
                                                                                        <i class="bi bi-trash"></i> Kaldır
                                                                                    </button>` : ''}
                                                                                </div>
                                                                                <div class="row g-3">`;

            alanlar.forEach(alan => {
                const inputName = `satir_${satirNo}_alan_${alan.id}`;

                html += `<div class="col-md-6">
                                                                                    <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
                                                                                        ${alan.alanAdi} ${alan.gerekli ? '<span style="color:#ef4444;">*</span>' : ''}
                                                                                    </label>`;

                if (alan.alanTipi === 'Metin') {
                    html += `<input type="text" name="${inputName}" class="form-control"
                                                                                             placeholder="${alan.alanAdi}..." ${alan.gerekli ? 'required' : ''}>`;
                } else if (alan.alanTipi === 'Uzun Metin') {
                    html += `<textarea name="${inputName}" class="form-control" rows="2"
                                                                                             placeholder="${alan.alanAdi}..." ${alan.gerekli ? 'required' : ''}></textarea>`;
                } else if (alan.alanTipi === 'Sayı') {
                    html += `<input type="number" name="${inputName}" class="form-control"
                                                                                             placeholder="0" ${alan.gerekli ? 'required' : ''}>`;
                } else if (alan.alanTipi === 'Tarih') {
                    html += `<input type="date" name="${inputName}" class="form-control"
                                                                                             ${alan.gerekli ? 'required' : ''}>`;
                } else if (alan.alanTipi === 'Checkbox') {
                    html += `<div class="form-check">
                                                                                        <input type="checkbox" name="${inputName}" value="Evet" class="form-check-input">
                                                                                        <label class="form-check-label">Evet</label>
                                                                                    </div>`;
                } else if (alan.alanTipi === 'Seçenek' && alan.secenekler) {
                    html += `<select name="${inputName}" class="form-select" ${alan.gerekli ? 'required' : ''}>
                                                                                        <option value="">— Seçin —</option>`;
                    alan.secenekler.split(',').forEach(s => {
                        html += `<option value="${s.trim()}">${s.trim()}</option>`;
                    });
                    html += `</select>`;
                } else if (alan.alanTipi === 'Kategori') {
                    html += `<div class="kategori-secicisi">
                                                                                        <select name="${inputName}_ust" class="form-select mb-2" onchange="altKategorileriGetir(this, '${inputName}', false)" ${alan.gerekli ? 'required' : ''}>
                                                                                            <option value="">— Ana Kategori Seçin —</option>
        @if (ViewBag.AnaKategoriler != null)
        {
            @foreach (var k in (IEnumerable<ArıtmaEnvanter.Models.Entities.Kategori>)ViewBag.AnaKategoriler)
            {
                                                                                                                                                                                                                                    <option value="@k.Ad" data-id="@k.Id">@k.Ad</option>
            }
        }
                                                                                        </select>
                                                                                        <select name="${inputName}" id="alt_${inputName}" class="form-select" ${alan.gerekli ? 'required' : ''}>
                                                                                            <option value="">— Önce Ana Kategori Seçin —</option>
                                                                                        </select>
                                                                                    </div>`;
                } else if (alan.alanTipi === 'Görsel') {
                    html += `<div>
                                                                                        <input type="file" name="${inputName}_file"
                                                                                               accept="image/*" class="form-control"
                                                                                               ${alan.gerekli ? 'required' : ''}
                                                                                               onchange="gorselOnizle(this, 'onizle_${inputName}')">
                                                                                        <div id="onizle_${inputName}" style="margin-top:8px;"></div>
                                                                                    </div>`;
                } else if (alan.alanTipi === 'Personel') {
                    html += `<select name="${inputName}" class="form-select" ${alan.gerekli ? 'required' : ''}>
                                                                                        <option value="">— Personel Seçin —</option>`;
                    personelListesi.forEach(grup => {
                        html += `<optgroup label="${grup.birim}">`;
                        grup.kisiler.forEach(p => {
                            html += `<option value="${p.ad}">${p.ad}${p.unvan ? ' — ' + p.unvan : ''}</option>`;
                        });
                        html += `</optgroup>`;
                    });
                    html += `</select>`;
                } else if (alan.alanTipi === 'Durum') {
                    html += `<div style="display:flex;gap:12px;align-items:center;">
                                                                        <label style="display:flex;align-items:center;gap:6px;background:#f0fdf4;border:2px solid #22c55e;border-radius:8px;padding:10px 20px;cursor:pointer;font-weight:600;color:#15803d;font-size:14px;transition:all 0.2s;">
                                                                            <input type="radio" name="${inputName}" value="Aktif" ${alan.gerekli ? 'required' : ''} style="accent-color:#22c55e;width:18px;height:18px;"> Aktif
                                                                        </label>
                                                                        <label style="display:flex;align-items:center;gap:6px;background:#fef2f2;border:2px solid #ef4444;border-radius:8px;padding:10px 20px;cursor:pointer;font-weight:600;color:#dc2626;font-size:14px;transition:all 0.2s;">
                                                                            <input type="radio" name="${inputName}" value="Pasif" style="accent-color:#ef4444;width:18px;height:18px;"> Pasif
                                                                        </label>
                                                                        <label style="display:flex;align-items:center;gap:6px;background:#fffbeb;border:2px solid #f59e0b;border-radius:8px;padding:10px 20px;cursor:pointer;font-weight:600;color:#b45309;font-size:14px;transition:all 0.2s;">
                                                                            <input type="radio" name="${inputName}" value="Hurda" style="accent-color:#f59e0b;width:18px;height:18px;"> Hurda
                                                                        </label>
                                                                    </div>`;
                } else if (alan.alanTipi === 'Birim') {
                    html += `<select name="${inputName}" class="form-select" ${alan.gerekli ? 'required' : ''}>
                                                                            <option value="">— Birim Seçin —</option>`;
                    birimListesi.forEach(grup => {
                        html += `<optgroup label="${grup.grup}">`;
                        grup.birimler.forEach(b => {
                            html += `<option value="${b.ad}">${b.ad}</option>`;
                        });
                        html += `</optgroup>`;
                    });
                    html += `</select>`;
                } else if (alan.alanTipi === 'Demirbaş') {
                    html += `<div style="display:flex;gap:8px;align-items:center;">
                                                                    <input id="demirbas_${inputName}" list="demirbas_list_${inputName}" name="${inputName}" class="form-control" placeholder="Demirbaş no girin veya okutun..." ${alan.gerekli ? 'required' : ''} style="flex:1;">
                                                                    <datalist id="demirbas_list_${inputName}">`;
                    urunListesi.forEach(grup => {
                        grup.urunler.forEach(u => {
                            const etiket = `${u.tur}${u.seri ? ' (Seri No: ' + u.seri + ')' : ''}${u.birim ? ' - ' + u.birim : ''}`;
                           
                            html += `<option value="${u.seri || u.tur}">${etiket}</option>`;
                        });
                    });
                    html += `</datalist>
                                                                    <button type="button" class="btn btn-primary d-flex align-items-center justify-content-center" onclick="startScanner('demirbas_${inputName}')" style="width:48px;height:38px;padding:0;flex-shrink:0;background:#00a8e8;border-color:#00a8e8;" title="Barkod Okut">
                                                                        <i class="bi bi-upc-scan" style="font-size:18px;"></i>
                                                                    </button>
                                                                </div>`;
                } else if (alan.alanTipi === 'Lokasyon') {
                    html += `<select name="${inputName}" class="form-select" ${alan.gerekli ? 'required' : ''}>
                                                                            <option value="">— Lokasyon Seçin —</option>`;
                    lokasyonListesi.forEach(l => {
                        const etiket = `${l.birim} - Kat: ${l.kat} - Oda: ${l.oda}`;
                        html += `<option value="${etiket}">${etiket}</option>`;
                    });
                    html += `</select>`;
                }

                html += `</div>`; 
            });

            html += `</div>`; 
            satirDiv.innerHTML = html;
            container.appendChild(satirDiv);

            
            $(`#satir_${satirNo} .form-select`).select2({
                placeholder: "Seçim yapın...",
                allowClear: true,
                width: '100%'
            });

            satirDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function satirSil(id) {
           
            $(`#${id} .form-select`).select2('destroy');
            document.getElementById(id)?.remove();
        }

        function gorselOnizle(input, hedefId) {
            const hedef = document.getElementById(hedefId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    hedef.innerHTML = `
                                                                                        <img src="${e.target.result}"
                                                                                             style="max-width:200px;max-height:150px;border-radius:8px;border:1px solid #e2e8f0;object-fit:cover;">
                                                                                        <div style="font-size:11px;color:#94a3b8;margin-top:4px;">${input.files[0].name}</div>`;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        
        let currentTargetSelectId = null;
        let isScannerRunning = false;

        function startScanner(targetSelectId) {
            currentTargetSelectId = targetSelectId;
            document.getElementById('barcodeModal').style.display = 'flex';

            if (isScannerRunning) return;

            
            Quagga.init({
                inputStream: {
                    name: "Live",
                    type: "LiveStream",
                    target: document.querySelector('#reader'),
                    constraints: {
                        width: 800,
                        height: 600,
                        facingMode: "environment"
                    },
                },
                locator: {
                    patchSize: "medium",
                    halfSample: true 
                },
                numOfWorkers: navigator.hardwareConcurrency ? navigator.hardwareConcurrency : 4,
                decoder: {
                    readers: [
                        { format: "code_128_reader", config: {} },
                        { format: "code_39_reader", config: {} },
                        "ean_reader",
                        "ean_8_reader",
                        "upc_reader",
                        "upc_e_reader"
                    ],
                    multiple: false
                },
                locate: true
            }, function (err) {
                if (err) {
                    console.error("Quagga başlatılamadı:", err);
                    alert("Kamera başlatılamadı. Lütfen izinlerinizi kontrol edin.");
                    document.getElementById('barcodeModal').style.display = 'none';
                    return;
                }
                Quagga.start();
                isScannerRunning = true;
            });

            Quagga.onDetected(onScanSuccess);

            
            Quagga.onProcessed(function (result) {
                var drawingCtx = Quagga.canvas.ctx.overlay,
                    drawingCanvas = Quagga.canvas.dom.overlay;

                if (result) {
                    if (result.boxes) {
                        drawingCtx.clearRect(0, 0, parseInt(drawingCanvas.getAttribute("width")), parseInt(drawingCanvas.getAttribute("height")));
                        result.boxes.filter(function (box) {
                            return box !== result.box;
                        }).forEach(function (box) {
                            Quagga.ImageDebug.drawPath(box, { x: 0, y: 1 }, drawingCtx, { color: "green", lineWidth: 2 });
                        });
                    }

                    if (result.box) {
                        Quagga.ImageDebug.drawPath(result.box, { x: 0, y: 1 }, drawingCtx, { color: "#00F", lineWidth: 2 });
                    }

                    if (result.codeResult && result.codeResult.code) {
                        Quagga.ImageDebug.drawPath(result.line, { x: 'x', y: 'y' }, drawingCtx, { color: 'red', lineWidth: 3 });
                    }
                }
            });
        }

        let succesfulReads = {}; 
        function onScanSuccess(result) {
            if (!result || !result.codeResult || !result.codeResult.code) return;

            const decodedText = result.codeResult.code;

            
            if (!succesfulReads[decodedText]) {
                succesfulReads[decodedText] = 1;
            } else {
                succesfulReads[decodedText]++;
            }

            if (succesfulReads[decodedText] >= 3) {
                stopScanner();
                succesfulReads = {}; 

                
                const inputElement = document.getElementById(currentTargetSelectId);
                if (inputElement) {
                    inputElement.value = decodedText;

                    
                    inputElement.style.transition = 'all 0.3s';
                    inputElement.style.boxShadow = '0 0 0 4px rgba(34, 197, 94, 0.3)';
                    inputElement.style.borderColor = '#22c55e';
                    setTimeout(() => {
                        inputElement.style.boxShadow = '';
                        inputElement.style.borderColor = '';
                    }, 1500);
                }
            }
        }

        function stopScanner() {
            if (isScannerRunning) {
                Quagga.stop();
                Quagga.offDetected(onScanSuccess);
                Quagga.offProcessed();
                isScannerRunning = false;
            }
            document.getElementById('barcodeModal').style.display = 'none';
        }

        satirEkle();
    </script>

    
    <style>
       
        #reader {
            position: relative;
            width: 100%;
            height: 300px;
            overflow: hidden;
            background: #000;
            border-radius: 8px;
        }

        #reader video,
        #reader canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        #reader canvas.drawing,
        #reader canvas.drawingBuffer {
            position: absolute;
        }
    </style>
    <div id="barcodeModal"
        style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);z-index:9999;align-items:center;justify-content:center;">
        <div style="background:#fff;padding:20px;border-radius:12px;width:90%;max-width:500px;position:relative;">
            <button type="button" onclick="stopScanner()"
                style="position:absolute;top:10px;right:10px;background:none;border:none;font-size:24px;color:#64748b;cursor:pointer;z-index:10;">&times;</button>
            <h4 style="margin-top:0;margin-bottom:16px;font-size:18px;color:#0f172a;"><i class="bi bi-upc-scan me-2"
                    style="color:#00a8e8;"></i>Barkod Okut</h4>
            <div id="reader"></div>
            <p style="text-align:center;margin-top:12px;font-size:13px;color:#64748b;">Barkodu kameraya yaklaştırarak tam
                netleşmesini sağlayın. Kırmızı çizgi barkodu kestiğinde otomatik okunur.</p>
        </div>
    </div>
}