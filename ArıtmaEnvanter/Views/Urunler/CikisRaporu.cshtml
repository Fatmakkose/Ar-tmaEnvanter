@model List<ArıtmaEnvanter.Models.Entities.DepoHareket>
@{
    ViewData["Title"] = "Ürün Çıkış Fişi";
    var personel = ViewBag.ZimmetlenenPersonel as ArıtmaEnvanter.Models.Entities.Personel;
    var ilkHareket = Model.FirstOrDefault();
}

<div class="report-container mt-4 mb-5" style="max-width:800px; margin:0 auto; background:#fff; border:1px solid #ccc; padding:40px; box-shadow:0 4px 15px rgba(0,0,0,0.05);">
    <div class="report-header" style="text-align:center; margin-bottom:30px; border-bottom:2px solid #333; padding-bottom:15px;">
        <img src="~/images/maskilogo.png" alt="MASKİ Logo" style="height: 70px; margin-bottom: 15px;" />
        <h3 style="margin:0; text-transform:uppercase; font-weight:800; letter-spacing:1px; color:#333;">Ürün Çıkış Fişi</h3>
        @if (ilkHareket != null && !string.IsNullOrEmpty(ilkHareket.CikisFormNo))
        {
            <div style="font-size:14px; font-weight:600; color:#555; margin-top:5px;">Belge No: @ilkHareket.CikisFormNo</div>
        }
    </div>

    @if (TempData["Basarili"] != null)
    {
        <div class="alert alert-success d-print-none mb-4">
            <i class="bi bi-check-circle-fill"></i> @TempData["Basarili"]
        </div>
    }
    
    @if (ilkHareket != null)
    {
        <table class="table table-bordered mb-4" style="border-color:#333;">
            <tbody>
                <tr>
                    <th style="width:30%; background:#f5f5f5;">Geçerlilik Tarihi/Saati</th>
                    <td>@ilkHareket.Tarih.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
                <tr>
                    <th style="background:#f5f5f5;">İşlemi Yapan</th>
                    <td>@ilkHareket.IslemYapanKisi</td>
                </tr>
            </tbody>
        </table>
    }

    <h5 style="font-weight:700; border-bottom:1px solid #ddd; padding-bottom:5px; margin-bottom:15px;">Ürün Bilgileri</h5>
    <table class="table table-bordered mb-4" style="border-color:#333;">
        <thead style="background:#f5f5f5;">
            <tr>
                <th>Ürün Adı</th>
                <th>Kategori/Tür</th>
                <th>Çıkış Kaynağı (Raf)</th>
                <th>Miktar</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var x in Model)
            {
                <tr>
                    <td style="font-weight:600;">@x.Malzeme?.Ad</td>
                    <td>@(x.Malzeme?.Kategori?.Ad ?? x.Malzeme?.MalzemeTuru ?? "-")</td>
                    <td>
                        @(x.KaynakDepo?.Ad ?? "-") / 
                        @(x.RafTanim?.Ad ?? "Genel Alan") 
                        @if (!string.IsNullOrEmpty(x.RafNo))
                        {
                            <span>(No: @x.RafNo)</span>
                        }
                    </td>
                    <td style="font-weight:700; font-size:15px;" class="text-danger">@x.Miktar.ToString("0.##") @(x.Malzeme?.Birim?.Ad ?? "Adet")</td>
                </tr>
            }
        </tbody>
    </table>

    @if (personel != null)
    {
        <div class="alert alert-warning mb-4" style="border-color:#e0a800; background-color:#fffdf5; color:#856404; font-weight:600;">
            <i class="bi bi-person-check-fill me-2"></i> Bu ürün(ler) personel <u>@personel.AdSoyad</u> üzerine zimmetlenmiştir.
        </div>
    }

    <div class="report-signatures mt-5 row text-center" style="margin-top:80px !important;">
        <div class="col-6">
            <p style="font-weight:700; margin-bottom:50px;">Teslim Eden</p>
            <p>.......................................</p>
            <p style="font-size:12px; color:#666;">İmza</p>
        </div>
        <div class="col-6">
            <p style="font-weight:700; margin-bottom:50px;">Teslim Alan</p>
            <p>
                @if(personel != null)
                {
                    <strong style="border-bottom:1px dotted #000; padding:0 20px;">@personel.AdSoyad</strong>
                }
                else
                {
                    <span>.......................................</span>
                }
            </p>
            <p style="font-size:12px; color:#666;">İmza</p>
        </div>
    </div>
</div>

<div class="text-center d-print-none mb-5">
    <button class="btn btn-secondary px-4 me-2" onclick="window.history.back()">
        <i class="bi bi-arrow-left"></i> Geri Dön
    </button>
    <a asp-action="Index" class="btn btn-success px-4 me-2">
        <i class="bi bi-boxes"></i> Ürünlere Dön
    </a>
    <button class="btn btn-primary px-4" onclick="window.print()">
        <i class="bi bi-printer"></i> Şimdi Yazdır
    </button>
</div>

@section Styles {
    <style>
        @@media print {
            body { background: white !important; }
            .report-container { border: none !important; box-shadow: none !important; padding: 0 !important; margin-top: 20px !important; }
            .main-wrap { margin-left: 0 !important; }
            .sidebar, .topbar { display: none !important; }
        }
    </style>
}
