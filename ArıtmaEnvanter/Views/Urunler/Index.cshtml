@section Scripts {
    <style>
                .malzeme-item:hover {
            background: #e8f4fd !important;
        }

                .malzeme-item.active {
            background: #d0eaff !important;
            font-weight: 600;
        }


    </style>
}
<script>
     
     (function () {
         var dropdown = document.getElementById('birimSecimDropdown');
         var input = document.getElementById('birimInput');
         if (dropdown && input) {
             dropdown.addEventListener('change', function () {
                 if (this.value === 'Manuel') {
                     input.value = '';
                     input.readOnly = false;
                     input.focus();
                 } else {
                     input.value = this.value;
                     input.readOnly = true;
                 }
             });
             input.value = dropdown.value;
             input.readOnly = true;
         }
     })();

  
     (function () {
         var malzemeArama = document.getElementById('malzemeArama');
         var malzemeListesi = document.getElementById('malzemeListesi');
         var malzemeIdHidden = document.getElementById('malzemeIdHidden');
         var malzemeSeciliInfo = document.getElementById('malzemeSeciliInfo');
         var malzemeSeciliAd = document.getElementById('malzemeSeciliAd');
         var malzemeSifirla = document.getElementById('malzemeSifirla');
         var malzemeBilgiKarti = document.getElementById('malzemeBilgiKarti');
         var malzemeBilgiIcerik = document.getElementById('malzemeBilgiIcerik');
         var container = document.getElementById('dynamic-fields-container');
         var girisKaydetBtn = document.getElementById('girisKaydetBtn');

         if (malzemeArama) {
             malzemeArama.addEventListener('focus', function () {
                 malzemeListesi.style.display = 'block';
             });

             malzemeArama.addEventListener('input', function () {
                 var filter = this.value.toLocaleLowerCase('tr-TR');
                 var items = malzemeListesi.querySelectorAll('.malzeme-item');
                 var count = 0;
                 items.forEach(function (item) {
                     var text = (item.getAttribute('data-ad') + ' ' + (item.getAttribute('data-alt') || '')).toLocaleLowerCase('tr-TR');
                     if (text.indexOf(filter) > -1) {
                         item.style.display = '';
                         count++;
                     } else {
                         item.style.display = 'none';
                     }
                 });
                 malzemeListesi.style.display = count > 0 ? 'block' : 'none';
             });

             document.addEventListener('click', function (e) {
                 if (!malzemeArama.contains(e.target) && !malzemeListesi.contains(e.target)) {
                     malzemeListesi.style.display = 'none';
                 }
             });
         }

         malzemeListesi?.addEventListener('click', function (e) {
             var item = e.target.closest('.malzeme-item');
             if (item) {
                 secMalzeme(item.getAttribute('data-id'), item.getAttribute('data-ad'), item.getAttribute('data-alt'));
             }
         });

         function secMalzeme(id, ad, alt) {
             malzemeIdHidden.value = id;
             malzemeSeciliAd.textContent = ad;
             document.getElementById('malzemeSeciliDetay').textContent = alt ? '(' + alt + ')' : '';
             document.getElementById('malzemeSecimAlani').style.display = 'none';
             malzemeSeciliInfo.style.display = 'block';
             if(girisKaydetBtn) girisKaydetBtn.disabled = false;
             malzemeBilgiKarti.style.display = 'none';
             container.innerHTML = '<div style="text-align:center; padding:10px; color:var(--text-muted); font-size:13px;"><i class="bi bi-hourglass-split"></i> Form alanları yükleniyor...</div>';

             fetch(`/Urunler/GetMalzemeFormAlanlari?malzemeId=${id}`)
                 .then(r => r.json())
                 .then(data => {
                     container.innerHTML = '';
                     if (data.success) {
                         if (data.malzeme) {
                             var bilgiHtml = '';
                             if (data.malzeme.aciklama) bilgiHtml += `<div class="mb-1"><i class="bi bi-card-text me-1"></i>${data.malzeme.aciklama}</div>`;
                             if (data.malzeme.kategori) bilgiHtml += `<div><i class="bi bi-tag me-1"></i>Kategori: <strong>${data.malzeme.kategori}</strong></div>`;
                             if (data.malzeme.malzemeTuru) bilgiHtml += `<div class="mt-1"><i class="bi bi-info-circle me-1"></i>Tür: <span class="badge bg-light text-dark">${data.malzeme.malzemeTuru}</span></div>`;
                             if (bilgiHtml) {
                                 malzemeBilgiIcerik.innerHTML = bilgiHtml;
                                 malzemeBilgiKarti.style.display = 'block';
                             }
                         }
                         if (data.alanlar && data.alanlar.length > 0) {
                             data.alanlar.forEach(alan => {
                                 var fieldHtml = `<div class="mb-3"><label class="form-label" style="font-weight:600; font-size:13px;">${alan.alanAdi} ${alan.gerekli ? '<span class="text-danger">*</span>' : ''}</label>`;
                                 if (alan.alanTipi === 'Metin' || alan.alanTipi === 'Uzun Metin') {
                                     fieldHtml += `<input type="text" name="DynamicField_${alan.id}" class="form-control" ${alan.gerekli ? 'required' : ''} />`;
                                 } else if (alan.alanTipi === 'Sayı') {
                                     fieldHtml += `<input type="number" step="any" name="DynamicField_${alan.id}" class="form-control" ${alan.gerekli ? 'required' : ''} />`;
                                 } else if (alan.alanTipi === 'Tarih') {
                                     fieldHtml += `<input type="date" name="DynamicField_${alan.id}" class="form-control" ${alan.gerekli ? 'required' : ''} />`;
                                 } else if (alan.alanTipi === 'Seçenek' && alan.secenekler) {
                                     var opts = alan.secenekler.split(',');
                                     fieldHtml += `<select name="DynamicField_${alan.id}" class="form-select" ${alan.gerekli ? 'required' : ''}><option value="">-- Seçiniz --</option>`;
                                     opts.forEach(o => { fieldHtml += `<option value="${o.trim()}">${o.trim()}</option>`; });
                                     fieldHtml += `</select>`;
                                 } else {
                                     fieldHtml += `<input type="text" name="DynamicField_${alan.id}" class="form-control" ${alan.gerekli ? 'required' : ''} />`;
                                 }
                                 fieldHtml += `</div>`;
                                 container.insertAdjacentHTML('beforeend', fieldHtml);
                             });
                         }
                     } else {
                         container.innerHTML = '<div class="alert alert-warning py-2 small">Form alanları yüklenemedi.</div>';
                     }
                 })
                 .catch(err => {
                     console.error(err);
                     container.innerHTML = '<div class="alert alert-danger py-2 small">Bir hata oluştu.</div>';
                 });
         }

         malzemeSifirla?.addEventListener('click', function () {
             document.getElementById('malzemeSecimAlani').style.display = 'block';
             malzemeSeciliInfo.style.display = 'none';
             malzemeIdHidden.value = '';
             malzemeArama.value = '';
             malzemeBilgiKarti.style.display = 'none';
             container.innerHTML = '';
             if(girisKaydetBtn) girisKaydetBtn.disabled = true;
         });
     })();

     
     (function () {
         var cikisSelect = document.getElementById('cikisMalzemeSelect');
         var cikisStokSelect = document.getElementById('cikisStokSelect');
         var cikisMiktarInput = document.getElementById('genelCikisMiktar');
         var btnListeyeEkle = document.getElementById('btnListeyeEkle');
         var cikisSeciliInfo = document.getElementById('cikisMalzemeSeciliInfo');
         var cikisSeciliAd = document.getElementById('cikisMalzemeSeciliAd');
         var cikisSifirlaBtn = document.getElementById('cikisMalzemeSifirla');

         if (cikisSelect) {
             cikisSelect.addEventListener('change', function () {
                 var id = this.value;
                 var ad = this.options[this.selectedIndex].text;
                 if (id) {
                     this.parentElement.style.display = 'none';
                     cikisSeciliInfo.style.display = 'block';
                     cikisSeciliAd.textContent = ad;
                     secCikisMalzeme(id);
                 }
             });
         }

         function secCikisMalzeme(id) {
             cikisStokSelect.innerHTML = '<option value="">Stoklar aranıyor...</option>';
             cikisStokSelect.disabled = true;
             fetch(`/Urunler/GetMalzemeMevcutStoklar?malzemeId=${id}`)
                 .then(r => r.json())
                 .then(data => {
                     if (data.success && data.stoklar.length > 0) {
                         var html = '<option value="">-- Raf/Stok Kaydı Seçin --</option>';
                         data.stoklar.forEach(s => {
                             html += `<option value="${s.id}" data-max="${s.miktar}" data-raf-text="${s.rafAd}" data-urun-adi="${s.urunAdi}" data-is-kimyasal="${s.isKimyasal}">${s.urunAdi} - Raf: ${s.rafAd} (${s.rafNo || 'No Yok'}) - Mevcut: ${s.miktar}</option>`;
                         });
                         cikisStokSelect.innerHTML = html;
                         cikisStokSelect.disabled = false;
                     } else {
                         cikisStokSelect.innerHTML = '<option value="">Stok bulunamadı!</option>';
                     }
                 });
         }

         if (cikisStokSelect) {
             cikisStokSelect.addEventListener('change', function () {
                 var selectedOpt = this.options[this.selectedIndex];
                 var maxMiktar = selectedOpt ? selectedOpt.getAttribute('data-max') : null;
                 var isKimyasal = selectedOpt ? selectedOpt.getAttribute('data-is-kimyasal') === 'true' : false;
                 var mevcutBilgi = document.getElementById('cikisMevcutStokBilgi');
                 var cikisTuruSelect = document.getElementById('genelCikisTuru');
                 var kimyasalDiv = document.getElementById('cikisKimyasalHesapDiv');

                 if (this.value && maxMiktar) {
                     cikisMiktarInput.disabled = false;
                     cikisMiktarInput.max = maxMiktar;
                     cikisMiktarInput.placeholder = 'Maks: ' + maxMiktar;
                     if (cikisTuruSelect) cikisTuruSelect.disabled = false;
                     btnListeyeEkle.disabled = false;
                     if (mevcutBilgi) mevcutBilgi.textContent = 'Mevcut stok: ' + maxMiktar + ' adet';
                     
                     if (kimyasalDiv) {
                         kimyasalDiv.style.display = isKimyasal ? 'block' : 'none';
                         if (isKimyasal) {
                             cikisMiktarInput.readOnly = true;
                             cikisMiktarInput.style.backgroundColor = "#f8f9fa";
                         } else {
                             cikisMiktarInput.readOnly = false;
                             cikisMiktarInput.style.backgroundColor = "#fff";
                         }
                     }
                 } else {
                     cikisMiktarInput.disabled = true;
                     cikisMiktarInput.max = '';
                     cikisMiktarInput.placeholder = 'Miktar';
                     if (cikisTuruSelect) cikisTuruSelect.disabled = true;
                     btnListeyeEkle.disabled = true;
                     if (mevcutBilgi) mevcutBilgi.textContent = '';
                     if (kimyasalDiv) kimyasalDiv.style.display = 'none';
                 }
             });
         }

         if (btnListeyeEkle) {
             btnListeyeEkle.addEventListener('click', function () {
                 var stokId = cikisStokSelect.value;
                 var miktar = parseFloat(cikisMiktarInput.value);
                 var maxMiktar = parseFloat(cikisMiktarInput.max);
                 var tur = document.getElementById('genelCikisTuru').value;
                 var selectedOpt = cikisStokSelect.options[cikisStokSelect.selectedIndex];
                 var isKimyasal = selectedOpt.getAttribute('data-is-kimyasal') === 'true';

                 if (!stokId || !miktar || miktar <= 0) {
                     alert('Geçerli bir miktar giriniz.');
                     return;
                 }
                 if (miktar > maxMiktar) {
                     alert('Stok miktarından fazla çıkış yapamazsınız.');
                     return;
                 }
                 if (isKimyasal && miktar % 25 !== 0) {
                     alert('Kimyasal çıkışları 25 (1 bidon/torba) katları olmalıdır. Lütfen bidon hesabını kullanınız.');
                     return;
                 }

                 var urunAdi = selectedOpt.getAttribute('data-urun-adi');
                 var rafAd = selectedOpt.getAttribute('data-raf-text');
                 var satirId = Date.now();
                 var miktarGosterim = isKimyasal ? (miktar / 25).toFixed(2).replace(/\.?0+$/, "") + " Bidon" : miktar;

                 var tr = `<tr data-satir-id="${satirId}">
                     <td>${urunAdi}</td>
                     <td>${rafAd}</td>
                     <td><span class="badge ${tur === 'Demirbaş' ? 'bg-danger' : 'bg-primary'}">${tur}</span></td>
                     <td><strong>${miktarGosterim}</strong></td>
                     <td style="text-align:center;">
                         <button type="button" class="btn btn-sm text-danger" onclick="satirSil(this, ${satirId})">✕</button>
                     </td>
                 </tr>`;

                 document.querySelector('#topluCikisTablosu tbody').insertAdjacentHTML('beforeend', tr);
                 document.getElementById('bosListeSatiri').style.display = 'none';
                 document.getElementById('genelCikisKaydetBtn').disabled = false;

                 var gizliHtml = `
                     <div data-grup-id="${satirId}">
                         <input type="hidden" name="items.Index" value="${satirId}" />
                         <input type="hidden" name="items[${satirId}].StokId" value="${stokId}" />
                         <input type="hidden" name="items[${satirId}].Miktar" value="${miktar.toString().replace('.', ',')}" />
                         <input type="hidden" name="items[${satirId}].CikisTuru" value="${tur}" />
                     </div>`;
                 document.getElementById('gizliGirdilerMekani').insertAdjacentHTML('beforeend', gizliHtml);

                if (tur === 'Demirbaş' || 'Tuketim') {
                    document.getElementById('genelPersonelDiv').style.display = 'block';
                    document.getElementById('genelPersonelSelect').required = true;
                }

              
                 cikisStokSelect.value = '';
                 cikisMiktarInput.value = '';
                 cikisMiktarInput.disabled = true;
                 btnListeyeEkle.disabled = true;
                 document.getElementById('cikisMevcutStokBilgi').textContent = '';
                 var kimyasalDiv = document.getElementById('cikisKimyasalHesapDiv');
                 if (kimyasalDiv) kimyasalDiv.style.display = 'none';
                 document.getElementById('cikisBidonAdet').value = '';
             });
         }

         function sifirlaSecimAlani() {
             if(cikisSelect) {
                 cikisSelect.parentElement.style.display = 'block';
                 cikisSelect.value = '';
             }
             if(cikisSeciliInfo) cikisSeciliInfo.style.display = 'none';
             if(cikisStokSelect) {
                 cikisStokSelect.innerHTML = '<option value="">Önce ürün seçiniz...</option>';
                 cikisStokSelect.disabled = true;
             }
             if(cikisMiktarInput) {
                 cikisMiktarInput.value = '';
                 cikisMiktarInput.disabled = true;
                 cikisMiktarInput.max = '';
                 cikisMiktarInput.placeholder = 'Miktar';
             }
             var cikisTuruSelect = document.getElementById('genelCikisTuru');
             if (cikisTuruSelect) cikisTuruSelect.disabled = true;
             if(btnListeyeEkle) btnListeyeEkle.disabled = true;
             var mevcutBilgi = document.getElementById('cikisMevcutStokBilgi');
             if (mevcutBilgi) mevcutBilgi.textContent = '';
         }

         cikisSifirlaBtn?.addEventListener('click', sifirlaSecimAlani);
     })();

     
     function satirSil(btn, satirId) {
         var satir = document.querySelector('tr[data-satir-id="' + satirId + '"]');
         if (satir) satir.remove();
         var grup = document.querySelector('[data-grup-id="' + satirId + '"]');
         if (grup) grup.remove();
         var tbody = document.querySelector('#topluCikisTablosu tbody');
         var kalanSatirlar = tbody.querySelectorAll('tr[data-satir-id]');
         if (kalanSatirlar.length === 0) {
             document.getElementById('bosListeSatiri').style.display = '';
             document.getElementById('genelCikisKaydetBtn').disabled = true;
             var gpd = document.getElementById('genelPersonelDiv');
             if (gpd) gpd.style.display = 'none';
         } else {
             var gpd = document.getElementById('genelPersonelDiv');
             if (gpd) {
                 var demirbas = Array.from(kalanSatirlar).some(function (r) { return r.querySelector('.badge.bg-danger'); });
                 gpd.style.display = demirbas ? 'block' : 'none';
             }
         }
     }

      function updateModalVisibility(modal) {
          if (!modal) return;
          
          const depoSelect = modal.querySelector('select[name="depoId"]') || modal.querySelector('select[name="DepoId"]');
          const rafSelect = modal.querySelector('select[name="rafTanimId"]');
          const rafNoAlani = modal.querySelector('#rafNoAlani') || modal.querySelector('input[name="rafNo"]')?.closest('.mb-3') || modal.querySelector('input[name="rafNo"]')?.closest('.mb-2');
          const rafSecimDiv = rafSelect?.closest('.mb-2') || rafSelect?.closest('.mb-3');
          const hesapAlani = modal.querySelector('#kimyasalHesaplamaAlani');
          const miktarInput = modal.querySelector('input[name="miktar"]');
          const bidonInput = modal.querySelector('#bidonAdetInput');

          let isGesDepo = false;
          let isKimyasalRaf = false;

          if (depoSelect && depoSelect.selectedIndex >= 0) {
              const depoMetni = depoSelect.options[depoSelect.selectedIndex].text.trim().toUpperCase();
              isGesDepo = (depoMetni === "GES DEPO");
          }

          if (rafSelect && rafSelect.selectedIndex >= 0) {
              const rafMetni = rafSelect.options[rafSelect.selectedIndex].text.trim().toUpperCase();
              isKimyasalRaf = rafMetni.includes("KİMYASAL") || rafMetni.includes("KIMYASAL");
          }

          if (rafSecimDiv) {
              rafSecimDiv.style.display = isGesDepo ? 'none' : 'block';
          }

          if (rafNoAlani) {
              rafNoAlani.style.display = (isGesDepo || isKimyasalRaf) ? 'none' : 'block';
          }

          if (hesapAlani && miktarInput && bidonInput) {
              if (isKimyasalRaf) {
                  hesapAlani.style.display = 'block';
                  miktarInput.readOnly = true;
                  miktarInput.style.backgroundColor = "#f8f9fa";
              } else {
                  hesapAlani.style.display = 'none';
                  miktarInput.readOnly = false;
                  miktarInput.style.backgroundColor = "#fff";
                  if (!bidonInput.value) bidonInput.value = "";
              }
          }
      }

      document.addEventListener('change', function (e) {
          if (!e.target) return;
          const modal = e.target.closest('.modal-content');
          if (!modal) return;

          if (e.target.name === 'depoId' || e.target.name === 'DepoId' || e.target.name === 'rafTanimId') {
              updateModalVisibility(modal);

              if (e.target.name === 'rafTanimId') {
                  const rafNoInput = modal.querySelector('input[name="rafNo"]');
                  const secilenMetin = e.target.options[e.target.selectedIndex].text.trim().toUpperCase();
                  const isKimyasal = secilenMetin.includes("KİMYASAL") || secilenMetin.includes("KIMYASAL");

                  if (e.target.value !== "" && secilenMetin !== "") {
                      if(rafNoInput) rafNoInput.value = secilenMetin.charAt(0) + "";
                      if (!isKimyasal && rafNoInput) {
                          rafNoInput.focus();
                      }
                  } else {
                      if(rafNoInput) rafNoInput.value = "";
                  }
              }
              
              if ((e.target.name === 'depoId' || e.target.name === 'DepoId') && e.target.options[e.target.selectedIndex].text.trim().toUpperCase() === "GES DEPO") {
                 const rSelect = modal.querySelector('select[name="rafTanimId"]');
                 const rInput = modal.querySelector('input[name="rafNo"]');
                 if (rSelect) rSelect.value = "";
                 if (rInput) rInput.value = "";
              }
          }
      });

     
     document.addEventListener('input', function (e) {
         if (!e.target) return;
         const modal = e.target.closest('.modal-content');
         if (!modal) return;

         if (e.target.name === 'rafNo') {
             const rafSelect = modal.querySelector('select[name="rafTanimId"]');
             if (rafSelect && rafSelect.value !== "") {
                 const prefix = rafSelect.options[rafSelect.selectedIndex].text.trim().toUpperCase().charAt(0) + "";
                 if (!e.target.value.startsWith(prefix)) {
                     e.target.value = prefix;
                 }
             }
         }

         if (e.target.id === 'bidonAdetInput' || e.target.id === 'cikisBidonAdet') {
             const miktarInput = e.target.id === 'bidonAdetInput' ? modal.querySelector('input[name="miktar"]') : document.getElementById('genelCikisMiktar');
             if(miktarInput) miktarInput.value = (parseFloat(e.target.value) || 0) * 25;
         }
     });
        
