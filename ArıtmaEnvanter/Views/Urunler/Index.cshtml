                toplamIade += parseFloat($(this).val()) || 0;
            });

            if (toplamIade <= 0) {
                alert("Lütfen iade edilecek miktarları giriniz.");
                return;
            }

            $("#topluIadeForm").submit();
        });
    });
            
     var sepet = [];

    function sepeteEkle(id, ad, birim, max) {
        if (sepet.find(x => x.stokId === id)) {
            alert("Bu ürün zaten listenizde.");
            return;
        }
        sepet.push({
            stokId: id,
            urunAdi: ad,
            birim: birim,
            miktar: 1,
            max: parseFloat(max.toString().replace(',', '.'))
        });
        sepetiGuncelle();
        $("#talepSepetiKonteyner").show();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function sepettenCikar(id) {
        sepet = sepet.filter(x => x.stokId !== id);
        sepetiGuncelle();
        if (sepet.length === 0) $("#talepSepetiKonteyner").hide();
    }

    function miktarGuncelle(id, miktar) {
        var urun = sepet.find(x => x.stokId === id);
        if (urun) {
            var m = parseInt(miktar);
            if(isNaN(m) || m < 1) m = 1;
            if(m > urun.max) {
                alert("Stok yetersiz! Maks: " + Math.floor(urun.max));
                urun.miktar = Math.floor(urun.max);
            } else {
                urun.miktar = m;
            }
        }
        sepetiGuncelle();
    }

    function sepetiGuncelle() {
        var html = "";
        sepet.forEach(item => {
            html += "<tr>";
            html += "<td>" + item.urunAdi + "</td>";
            html += "<td><div class='input-group input-group-sm'>";
            html += "<input type='number' class='form-control' value='" + item.miktar + "' step='1' min='1' onchange='miktarGuncelle(" + item.stokId + ", this.value)'>";
            html += "<span class='input-group-text'>" + item.birim + "</span></div></td>";
            html += "<td class='text-end'><button type='button' class='btn btn-sm text-danger' onclick='sepettenCikar(" + item.stokId + ")'>✕</button></td>";
            html += "</tr>";
        });
        $("#sepetTablosu tbody").html(html);
        $("#sepetUrunSayisi").text(sepet.length);
    }

       function talebiTamamla() {
        console.log("Talep gönder butonuna tıklandı");
        console.log("Sepet:", sepet);

        if (sepet.length === 0) {
            alert("Sepetinizde ürün yok!");
            return;
        }

        var requestData = {
            Items: sepet.map(x => ({
                StokId: x.stokId,
                Miktar: x.miktar
            })),
            Aciklama: ''
        };

        console.log("Gönderilecek data:", requestData);

       
        var tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        var token = tokenElement ? tokenElement.value : '';

        console.log("Token:", token);

        fetch('/Talepler/TopluTalepOlustur', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
                
            },
            body: JSON.stringify({
                ...requestData,
                __RequestVerificationToken: token
            })
        })
        .then(response => {
            console.log("HTTP Durum:", response.status);
            if (!response.ok) {
                return response.text().then(text => {
                    console.error("Hata yanıtı:", text);
                    throw new Error('HTTP Hatası: ' + response.status);
                });
            }
            return response.json();
        })
        .then(data => {
            console.log("Yanıt:", data);
            if (data.success) {
                alert(data.message);
                sepet = [];
                location.reload();
            } else {
                alert(data.message || "İşlem başarısız!");
            }
        })
        .catch(error => {
            console.error("Hata detayı:", error);
            alert("Bir hata oluştu: " + error.message);
        });
    }

    $(document).on('click', '.btn-sepet-ekle', function() {
        var stokId = $(this).data('id');
        var urunAdi = $(this).data('ad');
        var birim = $(this).data('birim');
        var maxMiktar = 999999;

        sepeteEkle(stokId, urunAdi, birim, maxMiktar);
    });

