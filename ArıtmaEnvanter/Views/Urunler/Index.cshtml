                            </select>
                        </div>

                        <div id="cikisMalzemeSeciliInfo" style="display:none; margin-bottom:10px; padding:10px 14px; background:#fff5f5; border-radius:8px; border:1px solid #ffcdcd; font-size:13px;">
                            <i class="bi bi-check-circle-fill text-danger"></i>
                            <strong id="cikisMalzemeSeciliAd"></strong>
                            <button type="button" id="cikisMalzemeSifirla" style="float:right; background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:12px;">✕ Değiştir</button>
                        </div>

                        <div class="mb-2">
                            <label class="form-label text-muted" style="font-size:12px;">Çıkış Yapılacak Raf (Stok Kaydı) <span class="text-danger">*</span></label>
                            <select id="cikisStokSelect" class="form-select form-select-sm border-danger" disabled>
                                <option value="">Önce ürün seçiniz...</option>
                            </select>
                            <small id="cikisMevcutStokBilgi" class="text-muted d-block mt-1" style="font-size:11px;"></small>
                        </div>

                        <div class="row g-2 align-items-end">
                            <div class="col-5">
                                <label class="form-label text-muted" style="font-size:12px;">Miktar <span class="text-danger">*</span></label>
                                <input type="number" step="1" id="genelCikisMiktar" class="form-control form-control-sm" min="1" placeholder="Miktar" disabled />
                            </div>
                            <div class="col-4">
                                <label class="form-label text-muted" style="font-size:12px;" >Çıkış Türü</label>
                                <select id="genelCikisTuru" class="form-select form-select-sm"  disabled>
                                    <option value="Tüketim">Sarf / Tüketim</option>
                                    <option value="Demirbaş">Demirbaş (Zimmet)</option>
                                </select>
                            </div>
                            <div class="col-3">
                                <button type="button" id="btnListeyeEkle" class="btn btn-sm btn-outline-danger w-100" disabled>
                                    <i class="bi bi-plus-circle"></i> Ekle
                                </button>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-2 text-danger border-bottom pb-2">Çıkış Yapılacak Ürünler Listesi</h6>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-bordered align-middle" id="topluCikisTablosu" style="font-size:13px;">
                            <thead class="table-light">
                                <tr>
                                    <th>Ürün</th>
                                    <th>Raf</th>
                                    <th>Tür</th>
                                    <th style="width:80px;">Miktar</th>
                                    <th style="width:40px; text-align:center;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr id="bosListeSatiri">
                                    <td colspan="5" class="text-center text-muted py-3">Listeye henüz ürün eklenmedi.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div id="gizliGirdilerMekani"></div>

                    <div class="mb-3 p-3 rounded" style="background:#f0f7ff; border:1px solid #cfe2ff; display:none;" id="genelPersonelDiv">
                        <label class="form-label fw-bold" style="font-size:13px; color:#084298;">
                            <i class="bi bi-person-check-fill me-1"></i> Teslim Alan Personel <span class="text-danger">*</span>
                        </label>
                        <select id="genelPersonelSelect" name="personelId" class="form-select border-primary">
                            <option value="">-- Personel Seçiniz --</option>
                            @if (ViewBag.Personeller != null)
                            {
                                foreach (var p in (List<ArıtmaEnvanter.Models.Entities.Personel>)ViewBag.Personeller)
                                {
                                    <option value="@p.Id">@p.AdSoyad</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" style="font-weight:600; font-size:13px;">Açıklama / Çıkış Nedeni (Opsiyonel)</label>
                        <textarea name="aciklama" class="form-control" rows="2" placeholder="Nereye/Kime çıkış yapıldı?"></textarea>
                    </div>

                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" id="genelCikisKaydetBtn" class="btn btn-danger" disabled>
                        <i class="bi bi-box-arrow-right"></i> Çıkışı Onayla
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
