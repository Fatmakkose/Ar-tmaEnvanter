                    <div class="mb-3 p-3 rounded" style="background:#f8f9fa; border:1px solid #ddd;">
                        <label class="form-label" style="font-weight:700; font-size:13px; color:var(--primary);">
                            <i class="bi bi-box-seam text-danger me-1"></i> Ürün Seçiniz
                        </label>

                        <div class="mb-3">
                            <select id="cikisMalzemeSelect" class="form-select border-danger" style="font-size:14px;">
                                <option value="">-- Çıkış Yapılacak Ürünü Seçin --</option>
                                @if (ViewBag.StoktakiMalzemeler != null)
                                {
                                    foreach (var m in (List<ArıtmaEnvanter.Models.Entities.Malzeme>)ViewBag.StoktakiMalzemeler)
