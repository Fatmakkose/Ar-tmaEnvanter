@model List<ArıtmaEnvanter.Models.Entities.DepoHareket>

@{
    ViewData["Title"] = "Stok Hareketleri";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2><i class="bi bi-clock-history me-2" style="color:var(--accent);"></i>Stok Hareketleri</h2>
        <p>Depoya giren, çıkan ve iade edilen tüm ürün hareketlerini görüntüleyin.</p>
    </div>
</div>

<div class="data-card mb-4" style="background:#f8faff; border:1px solid var(--border);">
    <div style="padding:16px 20px;">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label"
                        style="font-size:12px; font-weight:700; color:var(--primary);">Arama:</label>
                    <div class="search-box" style="width:100%;">
                        <i class="bi bi-search"></i>
                        <input type="text" name="arama" value="@ViewBag.Arama"
 />
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label" style="font-size:12px; font-weight:700; color:var(--primary);">İşlem
                        Türü:</label>
                    <select name="islemTipi" class="form-select">
                        <option value="">Tümü</option>
                        <option value="Giris" selected="@(ViewBag.IslemTipi == "Giris" ? "selected" : null)">Giriş /
                            Stok Ekleme</option>
                        <option value="Cikis" selected="@(ViewBag.IslemTipi == "Cikis" ? "selected" : null)">Çıkış
                        </option>
                        <option value="Iade" selected="@(ViewBag.IslemTipi == "Iade" ? "selected" : null)">İade Alma
                        </option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" style="font-size:12px; font-weight:700; color:var(--primary);">Başlangıç
                        Tarihi:</label>
                    <input type="date" name="baslangicTarihi" value="@ViewBag.BaslangicTarihi" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label" style="font-size:12px; font-weight:700; color:var(--primary);">Bitiş
                        Tarihi:</label>
                    <input type="date" name="bitisTarihi" value="@ViewBag.BitisTarihi" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn-action w-100"><i class="bi bi-funnel me-1"></i>Filtrele</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="data-card">
    @if (!Model.Any())

    {
        <div class="empty-state">
            <i class="bi bi-journal-x" style="font-size:48px; color:var(--accent); opacity:0.4;"></i>
            <p class="mt-3" style="font-size:15px; font-weight:600; color:var(--text-muted);">Gösterilecek stok hareketi
                bulunamadı.</p>
        </div>
    }

    else

    {
        <div class="d-flex justify-content-between align-items-center px-3 pt-3 pb-2">
            <span style="font-size:13px; color:var(--text-muted);">Toplam <strong>@Model.Count</strong> kayıt
                listeleniyor</span>
            <a href="@Url.Action("Rapor", new { arama = ViewBag.Arama, islemTipi = ViewBag.IslemTipi, baslangicTarihi = ViewBag.BaslangicTarihi, bitisTarihi = ViewBag.BitisTarihi })" target="_blank" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-printer me-1"></i>Yazdır / Rapor Al
            </a>
        </div>
        <div class="table-responsive">
            <table class="table align-middle m-0">
                <thead style="background:#f0f4f8;">
                    <tr>
                        <th>Tarih</th>
                        <th>Depo & Raf Bilgisi</th>
                        <th>Ürün Adı</th>
                        <th>Miktar</th>
                        <th>Teslim Alan</th>
                        <th>İşlem Yapan / Kullanıcı</th>
                        <th>İşlem Türü</th>
                        <th>Firma</th>
                        <th>Form/Belge No</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hareket in Model)
                    {

                        string islemTuru = "Belirsiz";

                        string islemRenk = "secondary";

                        string islemIkon = "bi-question-circle";



                        if (hareket.HedefDepoId == null)

                        {

                            islemTuru = "Çıkış";

                            islemRenk = "danger";

                            islemIkon = "bi-box-arrow-right";

                        }

                        else if (hareket.KaynakDepoId == hareket.HedefDepoId)

                        {

                            islemTuru = "Giriş / Ekleme";

                            islemRenk = "success";

                            islemIkon = "bi-box-arrow-in-right";

                        }

                        else if (hareket.KaynakDepoId == null && hareket.HedefDepoId != null)

                        {

                            islemTuru = "İade Alındı";

                            islemRenk = "info";

                            islemIkon = "bi-arrow-return-left";

                        }

                        else

                        {

                            islemTuru = "Transfer";

                            islemRenk = "secondary";

                            islemIkon = "bi-arrow-left-right";

                        }

                        <tr>
                            <td style="font-size:13px; color:var(--text-muted);">
                                @hareket.Tarih.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td style="font-size:13px;">
                                @if (islemTuru == "Çıkış")

                                {
                                    <div class="text-muted"><strong>@hareket.KaynakDepo?.Ad</strong></div>
                                }

                                else

                                {
                                    <div class="text-muted">Nereye: <strong>@(hareket.HedefDepo?.Ad ?? "Bilinmiyor")</strong></div>
                                }
                                @{
                                    bool isKimyasal = hareket.RafTanim != null && (hareket.RafTanim.Ad.ToUpper().Contains("KİMYASAL") || hareket.RafTanim.Ad.ToUpper().Contains("KIMYASAL"));
                                }
                                @if (!string.IsNullOrEmpty(hareket.RafNo) && !isKimyasal)
                                {
                                    <small class="text-secondary d-block">Raf: @hareket.RafNo</small>
                                }
                            </td>
                            <td style="font-weight:600; color:var(--primary);">
                                <div>@(hareket.Malzeme?.Ad ?? "Bilinmeyen Ürün")</div>

                                @if (hareket.FormKayit != null && hareket.FormKayit.Degerler != null && hareket.FormKayit.Degerler.Any())
                                {
                                    <div class="text-secondary" style="font-weight:400; font-size: 11px; margin-top: 4px; line-height: 1.4;">
                                        @foreach (var deger in hareket.FormKayit.Degerler)
                                        {
                                            <span class="badge bg-light text-dark border-0 me-1" style="font-size: 10px;">
                                                <i class="bi bi-tag me-1 text-info"></i>@deger.Deger
                                            </span>
                                        }
                                    </div>
                                }
                            </td>
                            <td>
                                <span style="font-size:15px; font-weight:800; color:var(--@islemRenk);">
                                    @hareket.Miktar.ToString("0.##") @(isKimyasal ? "KG" : (hareket.Malzeme?.Birim?.Ad ?? "Adet"))
                                </span>
                            </td>
                            <td>
                                @if (hareket.Personel != null)

                                {
                                    <span class="badge bg-white text-primary border border-primary-subtle">
                                        <i class="bi bi-person-check-fill me-1"></i> @hareket.Personel.AdSoyad
                                    </span>
                                }

                                else

                                {
                                    <span class="text-muted opacity-50">—</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border"><i class="bi bi-person me-1"></i>
                                    @(hareket.IslemYapanKisi ?? "Sistem")</span>
                            </td>
                            <td>
                                <span class="badge bg-@islemRenk text-white border-0"><i class="bi @islemIkon"></i>
                                    @islemTuru</span>
                            </td>
                            <td style="font-size:13px;">
                                @if (hareket.Firma != null)

                                {
                                    <span class="badge bg-warning text-dark border">
                                        <i class="bi bi-building me-1"></i>@hareket.Firma.FirmaAdi
                                    </span>
                                }

                                else

                                {
                                    <span class="text-muted opacity-50">—</span>
                                }
                            </td>
                            <td style="font-size:13px;">
                                @if (!string.IsNullOrEmpty(hareket.CikisFormNo))

                                {
                                    <span class="badge bg-light text-secondary border">@hareket.CikisFormNo</span>
                                }

                                else

                                {
                                    <span class="text-muted opacity-50">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>