@model ArıtmaEnvanter.Models.Entities.Malzeme
@{
    ViewData["Title"] = "Ürün Tanımını Düzenle";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb" style="font-size: 13px;">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted"><i class="bi bi-house-door"></i> MaSKİ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Ürün Tanımını Düzenle</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center gap-3">
        <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
            <i class="bi bi-pencil-square fs-2 text-primary"></i>
        </div>
        <div>
            <h2 class="m-0 fw-800" style="letter-spacing: -0.5px; color: #003d7a;">Ürün Tanımını Düzenle</h2>
            <p class="m-0 text-muted fs-6">@Model.Ad tanımını güncelleyin</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <form asp-action="Duzenle" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OlusturmaTarihi" />

            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 16px;">
                <div class="card-header border-0 p-4" style="background: #002d5a;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-info-circle text-info fs-5"></i>
                        <h5 class="m-0 text-white fw-bold">Ürün Bilgileri</h5>
                    </div>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary">Raf Numarası</label>
                            <input asp-for="Raf" class="form-control form-control-lg bg-light border-0 py-3 px-4" style="border-radius: 12px;" placeholder="Örn: A1-1">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary">Ürün Kodu / Alternatif Ad</label>
                            <input asp-for="AlternatifAd" class="form-control form-control-lg bg-light border-0 py-3 px-4" style="border-radius: 12px;" placeholder="Örn: V-101, Boru-PN16">
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-secondary">Ürün / Malzeme Adı <span class="text-danger">*</span></label>
                            <input asp-for="Ad" class="form-control form-control-lg bg-light border-0 py-3 px-4" style="border-radius: 12px;" placeholder="Örn: Sürgülü Vana, PE100 Boru..." required>
                            <span asp-validation-for="Ad" class="text-danger small"></span>
                        </div>

                       
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary">Varsayılan Birim</label>
                            <select asp-for="Birim" class="form-select form-select-lg bg-light border-0 py-3 px-4" style="border-radius: 12px;">
                                <option value="Adet">Adet</option>
                                <option value="Metre">Metre</option>
                                <option value="Kg">Kilogram (kg)</option>
                                <option value="Litre">Litre</option>
                                <option value="Set">Set / Takım</option>
                                <option value="Rulo">Rulo</option>
                                <option value="Torba">Torba</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-secondary">Dinamik Form Şablonu</label>
                            <select asp-for="FormSablonId" class="form-select form-select-lg bg-light border-0 py-3 px-4" style="border-radius: 12px;">
                                <option value="">— Şablon Yok —</option>
                                @if (ViewBag.Sablonlar != null)
                                {
                                    foreach (var s in ViewBag.Sablonlar)
                                    {
                                        <option value="@s.Id">@s.Baslik</option>
                                    }
                                }
                            </select>
                        </div>

                       
                        <div class="col-12 mt-4">
                            <label class="form-label fw-bold text-secondary">Açıklama</label>
                            <textarea asp-for="Aciklama" class="form-control bg-light border-0 py-3 px-4" rows="4" style="border-radius: 12px;" placeholder="Ürün hakkında teknik notlar..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2 mt-4">
                <button type="submit" class="btn btn-dark btn-lg px-5 py-3 d-flex align-items-center gap-2" style="border-radius: 12px; background: #003d7a;">
                    <i class="bi bi-save fs-5"></i>
                    <span class="fw-bold">Değişiklikleri Kaydet</span>
                </button>
                <a asp-action="Index" class="btn btn-light btn-lg px-5 py-3 text-muted fw-bold" style="border-radius: 12px;">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
