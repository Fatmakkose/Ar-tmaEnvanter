@{
    ViewData["Title"] = "Dashboard";
    var currentDistrictId = User.Claims.FirstOrDefault(c => c.Type == "DistrictId")?.Value;
}

@if (!User.IsInRole("Admin") && string.IsNullOrEmpty(currentDistrictId))
{
            <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex align-items-center p-4" style="background: #fff8e1; border-radius: 12px;">
                <i class="bi bi-exclamation-triangle-fill text-warning me-3" style="font-size: 32px;"></i>
                <div class="flex-grow-1">
                    <h5 class="fw-bold mb-1" style="color: #856404;">Henüz Bir Birime Atanmadınız</h5>
                    <p class="mb-0" style="color: #856404; font-size: 14px;">
                        Sistemdeki veri izolasyonu nedeniyle şu an herhangi bir kayıt göremiyorsunuz. 
                        <strong>Eğer yöneticiniz atama yaptıysa, yeni yetkilerinizin aktifleşmesi için lütfen güvenli çıkış yapıp tekrar giriş yapın.</strong>
                    </p>
                </div>
                <div class="ms-3">
                     <a href="/Account/Logout" class="btn btn-warning btn-sm fw-bold px-3" style="border-radius: 8px;">
                        <i class="bi bi-box-arrow-left"></i> Çıkış Yap ve Yenile
                     </a>
                </div>
            </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card s-blue">
            <div class="stat-icon" style="background:#eff6ff;">🏢</div>
            <div>
                <div class="stat-num">@ViewBag.BirimSayisi</div>
                <div class="stat-lbl">Toplam Birim</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card s-cyan">
            <div class="stat-icon" style="background:#e8f6fd;">📦</div>
            <div>
                <div class="stat-num">@ViewBag.UrunSayisi</div>
                <div class="stat-lbl">Toplam Ürün</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card s-green">
            <div class="stat-icon" style="background:#f0fdf4;">👥</div>
            <div>
                <div class="stat-num">@ViewBag.PersonelSayisi</div>
                <div class="stat-lbl">Toplam Personel</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="border-left:4px solid #f59e0b;">
            <div class="stat-icon" style="background:#fefce8;">📋</div>
            <div>
                <div class="stat-num">@ViewBag.AktifZimmetSayisi</div>
                <div class="stat-lbl">Aktif Zimmet</div>
            </div>
        </div>
    </div>
</div>


<div class="row g-4 mb-4">
   
    <div class="col-md-4">
        <div class="data-card" style="height:100%;">
            <div class="data-card-head">
                <h6><i class="bi bi-pie-chart-fill"></i> Ürün Durum Dağılımı</h6>
            </div>
            <div style="padding:24px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:60px;">
                <div style="width:100%; max-width:250px; aspect-ratio:1;">
                    <canvas id="durumGrafik"></canvas>
                </div>
                <div style="display:flex;gap:16px;flex-wrap:wrap;justify-content:center;">
                    <div style="display:flex;align-items:center;gap:6px;font-size:13px;">
                        <div style="width:12px;height:12px;border-radius:50%;background:#22c55e;"></div>
                        Aktif (@ViewBag.AktifSayisi)
                    </div>
                    <div style="display:flex;align-items:center;gap:6px;font-size:13px;">
                        <div style="width:12px;height:12px;border-radius:50%;background:#f59e0b;"></div>
                        Bakımda (@ViewBag.BakimdaSayisi)
                    </div>
                    <div style="display:flex;align-items:center;gap:6px;font-size:13px;">
                        <div style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></div>
                        Hurda (@ViewBag.HurdaSayisi)
                    </div>
                </div>
            </div>
        </div>
    </div>

   
    <div class="col-md-8">
        <div class="data-card" style="height:100%;">
            <div class="data-card-head">
                <h6><i class="bi bi-bar-chart-fill"></i> Birime Göre Ürün Dağılımı</h6>
            </div>
            <div style="padding:24px;">
                <canvas id="birimGrafik"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    
    <div class="col-md-5">
        <div class="data-card">
            <div class="data-card-head">
                <h6>
                    <i class="bi bi-tools"></i> Yaklaşan Bakımlar
                    <span class="record-count" style="background:#f59e0b;">30 Gün</span>
                </h6>
            </div>
            @if (ViewBag.YaklasanBakimlar != null && ((IEnumerable<dynamic>)ViewBag.YaklasanBakimlar).Any())
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Ürün</th>
                                <th>Bakım Tarihi</th>
                                <th>Kalan</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var b in (IEnumerable<ArıtmaEnvanter.Models.Entities.Bakim>)ViewBag.YaklasanBakimlar)
                            {
                                var kalan = (int)(b.SonrakiBakimTarihi!.Value - DateTime.UtcNow).TotalDays;
                                    <tr>
                                        <td><strong>@System.Text.RegularExpressions.Regex.Replace(b.Urun?.UrunTuru ?? "", @"\s*\(\d+(\.\d+)*\)", "")</strong></td>
                                        <td style="font-size:13px;color:#64748b;">
                                        @b.SonrakiBakimTarihi?.ToLocalTime().ToString("dd.MM.yyyy")

                                        </td>
                                        <td>
                                            <span style="background:#fef9c3;color:#92400e;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">
                                            @kalan gün
                                            </span>
                                        </td>
                                    </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                        <div class="empty-state">
                            <i class="bi bi-check-circle" style="font-size:36px;opacity:0.3;display:block;margin-bottom:10px;color:#22c55e;"></i>
                            <p style="color:#22c55e;font-weight:600;">Yaklaşan bakım yok!</p>
                        </div>
            }
        </div>
    </div>

    
    <div class="col-md-7">
        <div class="data-card">
            <div class="data-card-head">
                <h6><i class="bi bi-clock-history"></i> Son Eklenen Ürünler</h6>
                <a href="/Urun/Index" class="btn-edit"><i class="bi bi-arrow-right"></i> Tümü</a>
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Ürün Adı</th>
                            <th>Birim</th>
                            <th>Kategori</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.SonUrunler != null)
                        {
                            foreach (var u in (IEnumerable<ArıtmaEnvanter.Models.Entities.Malzeme>)ViewBag.SonUrunler)
                            {
                                        <tr>
                                            <td><strong>@System.Text.RegularExpressions.Regex.Replace(u.UrunTuru ?? u.Ad ?? "", @"\s*\(\d+(\.\d+)*\)", "")</strong></td>
                                            <td style="color:#64748b;font-size:13px;">@u.Birim?.Ad</td>
                                            <td style="color:#64748b;font-size:13px;">@u.Kategori?.Ad</td>
                                            <td>
                                        @if (u.Durum == "Aktif")
                                        {
                                                        <span class="badge-aktif"><i class="bi bi-check-circle-fill"></i> Aktif</span>
                                        }
                                        else if (u.Durum == "Bakımda")
                                        {
                                                        <span class="badge-bakimda"><i class="bi bi-tools"></i> Bakımda</span>
                                        }
                                        else
                                        {
                                                        <span class="badge-hurda"><i class="bi bi-x-circle-fill"></i> Hurda</span>
                                        }
                                            </td>
                                        </tr>
                            }
                        }
                        else
                        {
                                <tr><td colspan="4" class="text-center py-4" style="color:#94a3b8;">Henüz ürün eklenmedi</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script>
                
                const durumCtx = document.getElementById('durumGrafik').getContext('2d');
                new Chart(durumCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Aktif', 'Bakımda', 'Hurda'],
                        datasets: [{
                            data: [@ViewBag.AktifSayisi, @ViewBag.BakimdaSayisi, @ViewBag.HurdaSayisi],
                            backgroundColor: ['#22c55e', '#f59e0b', '#ef4444'],
                            borderWidth: 2,
                            borderColor: '#fff'
                        }]
                    },
                    options: {
                        responsive: false,
                        plugins: {
                            legend: { display: false }
                        },
                        cutout: '65%'
                    }
                });

                
                const birimCtx = document.getElementById('birimGrafik').getContext('2d');
                new Chart(birimCtx, {
                    type: 'bar',
                    data: {
                        labels: [@Html.Raw(string.Join(",", ((Dictionary<string, int>)ViewBag.BirimUrunler).Keys.Select(k => $"'{k}'")))],
                        datasets: [{
                            label: 'Ürün Sayısı',
                            data: [@Html.Raw(string.Join(",", ((Dictionary<string, int>)ViewBag.BirimUrunler).Values))],
                            backgroundColor: '#003d7a',
                            borderRadius: 6,
                            borderSkipped: false
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { stepSize: 1 },
                                grid: { color: '#f1f4fa' }
                            },
                            x: {
                                grid: { display: false }
                            }
                        }
                    }
                });
            </script>
}